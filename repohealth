#!/usr/bin/env bash

set -u

PROGRAM_NAME="${0##*/}"

DIRTY_ONLY=0
MAX_DEPTH=""
CHECK_MODE=0
DETAIL_MODE=0
OUTPUT=""
REMOTE_OVERRIDE=""
PARALLEL_JOBS=""
EXCLUDE_PATTERNS=()
SCAN_ROOTS=()
SCAN_ROOT_CANONS=()
STATE_TMP_DIR=""

HAVE_GIT=0
HAVE_JJ=0
FD_CMD=""
ENABLE_COLOR=0
TERM_COLS_CACHE=""
COLLECT_DETAIL_DATA=0

REPO_ROOTS=()
REPO_TYPES=()

REPO_PUSH_KIND=()
REPO_PUSH_PLAIN=()
REPO_PUSH_NOTE=()
REPO_PUSH_DETAIL=()

REPO_WORK_KIND=()
REPO_WORK_PLAIN=()
REPO_WORK_NOTE=()
REPO_WORK_DETAIL=()
REPO_UNTRACKED_DETAIL=()
REPO_DRAFT_DETAIL=()

usage() {
  cat <<EOF
Usage: $PROGRAM_NAME [options] [directory ...]

Scan nested Git and Jujutsu repos and report outgoing commits plus working-copy changes.

Options:
  -d, --dirty           Show only repos with non-clean push or working-copy status
  -n, --depth N         Limit traversal depth
  -c, --check           Exit non-zero when any repo needs attention
  -r, --remote NAME     Override the remote used for JJ push checks
  -j, --jobs N          Collect repo state in parallel with up to N workers
  -e, --exclude PATTERN Exclude repos whose path matches the ERE (may be repeated)
  -o, --output FORMAT   Output format: json, fancy, no-color (default: human-readable table)
  -D, --detail          Show per-repo detailed sections
  -h, --help            Show this help text
EOF
}

die() {
  echo "Error: $*" >&2
  exit 1
}

warn() {
  echo "Warning: $*" >&2
}

command_exists() {
  command -v "$1" >/dev/null 2>&1
}

json_escape() {
  local _var="$1" _s="$2"
  _s="${_s//\\/\\\\}"
  _s="${_s//\"/\\\"}"
  _s="${_s//$'\r'/\\r}"
  _s="${_s//$'\n'/\\n}"
  _s="${_s//$'\t'/\\t}"
  printf -v "$_var" '%s' "$_s"
}

print_json_string_array() {
  local indent="$1"
  local block="$2"
  local first=1 line je

  block="$(trim_trailing_newlines "$block")"
  if [ -z "$block" ]; then
    printf '[]'
    return
  fi

  printf '[\n'
  while IFS= read -r line; do
    [ -n "$line" ] || continue
    [ "$first" -eq 0 ] && printf ',\n'
    first=0
    json_escape je "$line"
    printf '%s  "%s"' "$indent" "$je"
  done <<EOF
$block
EOF
  printf '\n%s]' "$indent"
}

print_json_numstat_array() {
  local indent="$1"
  local block="$2"
  local first=1 added removed path je

  block="$(trim_trailing_newlines "$block")"
  if [ -z "$block" ]; then
    printf '[]'
    return
  fi

  printf '[\n'
  while IFS=$'\t' read -r added removed path; do
    [ -n "$added$removed$path" ] || continue
    [ "$first" -eq 0 ] && printf ',\n'
    first=0
    printf '%s  {\n' "$indent"
    if [ "$added" = "-" ]; then
      printf '%s    "added": null,\n' "$indent"
    else
      printf '%s    "added": %s,\n' "$indent" "$added"
    fi
    if [ "$removed" = "-" ]; then
      printf '%s    "removed": null,\n' "$indent"
    else
      printf '%s    "removed": %s,\n' "$indent" "$removed"
    fi
    json_escape je "$path"
    printf '%s    "path": "%s"\n' "$indent" "$je"
    printf '%s  }' "$indent"
  done <<EOF
$block
EOF
  printf '\n%s]' "$indent"
}

print_json_commit_detail_array() {
  local indent="$1"
  local raw="$2"
  local first=1 line current_title current_stats je
  local tab=$'\t'

  raw="$(trim_trailing_newlines "$raw")"
  if [ -z "$raw" ]; then
    printf '[]'
    return
  fi

  printf '[\n'
  current_title=""
  current_stats=""
  while IFS= read -r line; do
    case "$line" in
    "__C__${tab}"*)
      current_title="${line#"__C__${tab}"}"
      current_stats=""
      ;;
    "__E__")
      [ "$first" -eq 0 ] && printf ',\n'
      first=0
      printf '%s  {\n' "$indent"
      json_escape je "$current_title"
      printf '%s    "title": "%s",\n' "$indent" "$je"
      printf '%s    "files": ' "$indent"
      print_json_numstat_array "${indent}    " "$current_stats"
      printf '\n%s  }' "$indent"
      current_title=""
      current_stats=""
      ;;
    *)
      if [ -n "$current_stats" ]; then
        current_stats="${current_stats}"$'\n'"$line"
      else
        current_stats="$line"
      fi
      ;;
    esac
  done <<EOF
$raw
EOF

  printf '\n%s]' "$indent"
}

canonicalize_dir() {
  local path="$1"
  if command_exists realpath; then
    realpath "$path"
  else
    (
      cd "$path" 2>/dev/null && pwd -P
    )
  fi
}

display_path() {
  local path="$1"
  local i root
  for ((i = 0; i < ${#SCAN_ROOT_CANONS[@]}; i++)); do
    root="${SCAN_ROOT_CANONS[$i]}"
    case "$path" in
    "$root")
      if [ "${#SCAN_ROOT_CANONS[@]}" -eq 1 ]; then
        printf '.'
        return
      fi
      ;;
    "$root"/*)
      printf '%s' "${path#"$root"/}"
      return
      ;;
    esac
  done
  if [ -n "${HOME:-}" ]; then
    case "$path" in
    "$HOME")
      printf '~'
      return
      ;;
    "$HOME"/*)
      printf '~/%s' "${path#"$HOME"/}"
      return
      ;;
    esac
  fi
  printf '%s' "$path"
}

is_integer() {
  case "$1" in
  '' | *[!0-9]*)
    return 1
    ;;
  *)
    return 0
    ;;
  esac
}

default_parallel_jobs() {
  local jobs=""
  if command_exists getconf; then
    jobs="$(getconf _NPROCESSORS_ONLN 2>/dev/null || true)"
  fi
  if [ -z "$jobs" ] && command_exists sysctl; then
    jobs="$(sysctl -n hw.ncpu 2>/dev/null || true)"
  fi
  if ! is_integer "$jobs" || [ "$jobs" -lt 1 ]; then
    jobs=4
  fi
  if [ "$jobs" -lt 8 ]; then
    jobs=8
  fi
  printf '%s' "$jobs"
}

status_color() {
  local kind="$1"
  case "$kind" in
  clean)
    printf '\033[32m'
    ;;
  outgoing)
    printf '\033[36m'
    ;;
  changes | draft | behind | diverged)
    printf '\033[33m'
    ;;
  question)
    printf '\033[2m'
    ;;
  push_failed | error | unavailable)
    printf '\033[31m'
    ;;
  *)
    printf ''
    ;;
  esac
}

colorize_status() {
  local kind="$1"
  local text="$2"
  local color
  if [ "$ENABLE_COLOR" -ne 1 ]; then
    printf '%s' "$text"
    return
  fi
  color="$(status_color "$kind")"
  if [ -z "$color" ]; then
    printf '%s' "$text"
  else
    printf '%b%s%b' "$color" "$text" '\033[0m'
  fi
}

trim_trailing_newlines() {
  local value="$1"
  while [ "${value%$'\n'}" != "$value" ]; do
    value="${value%$'\n'}"
  done
  printf '%s' "$value"
}

cleanup_temp_state() {
  if [ -n "$STATE_TMP_DIR" ] && [ -d "$STATE_TMP_DIR" ]; then
    rm -rf "$STATE_TMP_DIR"
  fi
}

make_temp_dir() {
  local base="${TMPDIR:-/tmp}"
  local dir=""
  if command_exists mktemp; then
    dir="$(mktemp -d "$base/repohealth.XXXXXX" 2>/dev/null || true)"
  fi
  if [ -n "$dir" ]; then
    printf '%s' "$dir"
    return 0
  fi

  local candidate attempt=0
  while [ "$attempt" -lt 100 ]; do
    candidate="$base/repohealth.$$.$RANDOM"
    if mkdir "$candidate" 2>/dev/null; then
      printf '%s' "$candidate"
      return 0
    fi
    attempt=$((attempt + 1))
  done
  return 1
}

first_nonempty_line() {
  printf '%s\n' "$1" | awk 'NF { print; exit }'
}

count_nonempty_lines() {
  printf '%s\n' "$1" | awk 'NF { count++ } END { print count + 0 }'
}

contains_line() {
  local haystack="$1"
  local needle="$2"
  printf '%s\n' "$haystack" | grep -F "$needle" >/dev/null 2>&1
}

find_repo_index() {
  local root="$1"
  local i
  for ((i = 0; i < ${#REPO_ROOTS[@]}; i++)); do
    if [ "${REPO_ROOTS[$i]}" = "$root" ]; then
      printf '%s' "$i"
      return 0
    fi
  done
  return 1
}

init_repo_slot() {
  REPO_PUSH_KIND+=("")
  REPO_PUSH_PLAIN+=("")
  REPO_PUSH_NOTE+=("")
  REPO_PUSH_DETAIL+=("")
  REPO_WORK_KIND+=("")
  REPO_WORK_PLAIN+=("")
  REPO_WORK_NOTE+=("")
  REPO_WORK_DETAIL+=("")
  REPO_UNTRACKED_DETAIL+=("")
  REPO_DRAFT_DETAIL+=("")
}

add_repo() {
  local root="$1"
  local type="$2"
  local idx
  if idx="$(find_repo_index "$root")"; then
    if [ "${REPO_TYPES[$idx]}" = "git" ] && [ "$type" = "jj" ]; then
      REPO_TYPES[$idx]="jj"
    fi
    return
  fi

  REPO_ROOTS+=("$root")
  REPO_TYPES+=("$type")
  init_repo_slot
}

is_linked_worktree_gitfile() {
  local gitfile="$1"
  local first_line
  IFS= read -r first_line <"$gitfile" || return 1
  case "$first_line" in
  gitdir:\ *"/worktrees/"*)
    return 0
    ;;
  *)
    return 1
    ;;
  esac
}

discover_repos() {
  local scan_root="$1"
  local scan_cmd
  if [ -n "$FD_CMD" ]; then
    scan_cmd=("$FD_CMD" --hidden --no-ignore --print0)
    local excl
    for excl in node_modules vendor bower_components target __pycache__ .svn .hg; do
      scan_cmd+=(--exclude "$excl")
    done
    if [ -n "$MAX_DEPTH" ]; then
      scan_cmd+=(--max-depth "$MAX_DEPTH")
    fi
    scan_cmd+=(-t d -t f '^\.(git|jj)$' "$scan_root")
  else
    scan_cmd=(find "$scan_root")
    if [ -n "$MAX_DEPTH" ]; then
      scan_cmd+=(-maxdepth "$MAX_DEPTH")
    fi
    scan_cmd+=(
      "("
      -type d
      "("
      -name node_modules -o
      -name vendor -o
      -name bower_components -o
      -name target -o
      -name __pycache__ -o
      -name .svn -o
      -name .hg
      ")"
      -prune
      ")"
      -o
      "("
      -type d
      "("
      -name .git -o
      -name .jj
      ")"
      -print0
      -prune
      ")"
      -o
      "("
      -type f
      -name .git
      -print0
      ")"
    )
  fi

  local marker candidate type normalized_root
  while IFS= read -r -d '' marker; do
    # fd appends a trailing slash to directory results; strip it for consistent handling.
    marker="${marker%/}"
    candidate="${marker%/*}"
    # fd traverses into .git dirs; skip markers nested inside them.
    if [ -n "$FD_CMD" ]; then
      case "$candidate" in
        */.git | */.git/*) continue ;;
      esac
    fi
    type="git"
    if [ "${marker##*/}" = ".jj" ]; then
      type="jj"
    elif [ -f "$marker" ] && is_linked_worktree_gitfile "$marker"; then
      warn "Skipping linked worktree at $candidate"
      continue
    fi

    normalized_root="$candidate"

    normalized_root="$(canonicalize_dir "$normalized_root" 2>/dev/null || true)"
    if [ -z "$normalized_root" ]; then
      normalized_root="$candidate"
    fi

    if [ "${#EXCLUDE_PATTERNS[@]}" -gt 0 ]; then
      local rel_path
      rel_path="$(display_path "$normalized_root")"
      local pat excluded=0
      for pat in "${EXCLUDE_PATTERNS[@]}"; do
        if [[ "$rel_path" =~ $pat ]]; then
          excluded=1
          break
        fi
      done
      if [ "$excluded" -eq 1 ]; then
        continue
      fi
    fi

    add_repo "$normalized_root" "$type"
  done < <("${scan_cmd[@]}")
}

sort_repos() {
  local count="${#REPO_ROOTS[@]}"
  [ "$count" -le 1 ] && return
  local i root idx
  local new_roots=() new_types=()
  while IFS=$'\t' read -r root idx; do
    new_roots+=("$root")
    new_types+=("${REPO_TYPES[$idx]}")
  done < <(
    for ((i = 0; i < count; i++)); do
      printf '%s\t%s\n' "${REPO_ROOTS[$i]}" "$i"
    done | sort
  )
  REPO_ROOTS=("${new_roots[@]}")
  REPO_TYPES=("${new_types[@]}")
}

set_push_status() {
  local idx="$1"
  local kind="$2"
  local text="$3"
  local note="${4:-}"
  local detail="${5:-}"
  REPO_PUSH_KIND[$idx]="$kind"
  REPO_PUSH_PLAIN[$idx]="$text"
  REPO_PUSH_NOTE[$idx]="$note"
  REPO_PUSH_DETAIL[$idx]="$detail"
}

set_work_status() {
  local idx="$1"
  local kind="$2"
  local text="$3"
  local note="${4:-}"
  local detail="${5:-}"
  local untracked="${6:-}"
  REPO_WORK_KIND[$idx]="$kind"
  REPO_WORK_PLAIN[$idx]="$text"
  REPO_WORK_NOTE[$idx]="$note"
  REPO_WORK_DETAIL[$idx]="$detail"
  REPO_UNTRACKED_DETAIL[$idx]="$untracked"
}

set_draft_detail() {
  local idx="$1"
  local detail="$2"
  REPO_DRAFT_DETAIL[$idx]="$detail"
}

is_repo_clean() {
  local idx="$1"
  [ "${REPO_PUSH_KIND[$idx]}" = "clean" ] && [ "${REPO_WORK_KIND[$idx]}" = "clean" ]
}

join_counts() {
  local modified="$1"
  local untracked="$2"
  if [ "$modified" -gt 0 ] && [ "$untracked" -gt 0 ]; then
    printf '* %s modified, %s untracked' "$modified" "$untracked"
  elif [ "$modified" -gt 0 ]; then
    printf '* %s modified' "$modified"
  elif [ "$untracked" -gt 0 ]; then
    printf '* %s untracked' "$untracked"
  else
    printf -- '- clean'
  fi
}

terminal_columns() {
  [ -n "$TERM_COLS_CACHE" ] && { printf '%s' "$TERM_COLS_CACHE"; return; }
  local columns="${COLUMNS:-}"
  if is_integer "$columns" && [ "$columns" -ge 40 ]; then
    TERM_COLS_CACHE="$columns"
  else
    TERM_COLS_CACHE="80"
  fi
  printf '%s' "$TERM_COLS_CACHE"
}

truncate_middle() {
  local text="$1"
  local max_width="$2"
  local text_length left_width right_width right_start

  text_length=${#text}
  if [ "$text_length" -le "$max_width" ]; then
    printf '%s' "$text"
    return
  fi

  if [ "$max_width" -le 3 ]; then
    printf '%s' "${text:0:max_width}"
    return
  fi

  left_width=$(((max_width - 3) / 2))
  right_width=$((max_width - 3 - left_width))
  right_start=$((text_length - right_width))

  printf '%s...%s' "${text:0:left_width}" "${text:right_start}"
}

repeat_char() {
  local char="$1"
  local count="$2"
  [ "$count" -le 0 ] 2>/dev/null && return
  printf '%*s' "$count" '' | tr ' ' "$char"
}

make_diff_bar() {
  local add_chars="$1"
  local remove_chars="$2"
  local add_s remove_s
  add_s="$(repeat_char '+' "$add_chars")"
  remove_s="$(repeat_char '-' "$remove_chars")"
  if [ "$ENABLE_COLOR" -eq 1 ]; then
    if [ -n "$add_s" ]; then
      printf '\033[32m%s\033[0m' "$add_s"
    fi
    if [ -n "$remove_s" ]; then
      printf '\033[31m%s\033[0m' "$remove_s"
    fi
  else
    printf '%s%s' "$add_s" "$remove_s"
  fi
}

make_block_diff_bar() {
  local add_chars="$1"
  local remove_chars="$2"
  local empty_chars="$3"
  local add_s="" remove_s="" empty_s="" i
  for ((i = 0; i < add_chars; i++)); do add_s="${add_s}█"; done
  for ((i = 0; i < remove_chars; i++)); do remove_s="${remove_s}▓"; done
  for ((i = 0; i < empty_chars; i++)); do empty_s="${empty_s}░"; done
  if [ "$ENABLE_COLOR" -eq 1 ]; then
    [ -n "$add_s" ]    && printf '\033[32m%s\033[0m' "$add_s"
    [ -n "$remove_s" ] && printf '\033[31m%s\033[0m' "$remove_s"
    [ -n "$empty_s" ]  && printf '\033[2m%s\033[0m'  "$empty_s"
  else
    printf '%s%s%s' "$add_s" "$remove_s" "$empty_s"
  fi
}

ltrim_spaces() {
  local v="$1"
  while [ -n "$v" ] && [ "${v# }" != "$v" ]; do v="${v# }"; done
  printf '%s' "$v"
}

tsv_max_total() {
  local block="$1"
  local max=0 added removed path t
  block="$(trim_trailing_newlines "$block")"
  [ -n "$block" ] || { printf '0'; return; }
  while IFS=$'\t' read -r added removed path; do
    [ -n "$added$removed$path" ] || continue
    added="$(ltrim_spaces "$added")"
    removed="$(ltrim_spaces "$removed")"
    if [ "$added" != "-" ] && [ "$removed" != "-" ]; then
      t=$((added + removed))
      if [ "$t" -gt "$max" ]; then max="$t"; fi
    fi
  done <<EOF
$block
EOF
  printf '%s' "$max"
}

format_compact_stat_tsv() {
  local block="$1"
  local indent="${2:-7}"
  local forced_max_total="${3:-0}"
  local added removed path total
  local count=0 total_added=0 total_removed=0 binary_count=0
  local max_total=0 columns available_width path_width count_width bar_width i
  local add_col_width=0 del_col_width=0
  local paths=() added_list=() removed_list=() is_binary=()
  local result=""
  local file_word="files"

  block="$(trim_trailing_newlines "$block")"
  if [ -z "$block" ]; then
    return
  fi

  while IFS=$'\t' read -r added removed path; do
    [ -n "$added$removed$path" ] || continue

    added="$(ltrim_spaces "$added")"
    removed="$(ltrim_spaces "$removed")"

    count=$((count + 1))
    if [ "$added" = "-" ] || [ "$removed" = "-" ]; then
      paths+=("$path")
      added_list+=(0)
      removed_list+=(0)
      is_binary+=(1)
      binary_count=$((binary_count + 1))
    else
      total=$((added + removed))
      paths+=("$path")
      added_list+=("$added")
      removed_list+=("$removed")
      is_binary+=(0)
      total_added=$((total_added + added))
      total_removed=$((total_removed + removed))
      if [ "$total" -gt "$max_total" ]; then
        max_total="$total"
      fi
    fi
  done <<EOF
$block
EOF

  if [ "$count" -eq 0 ]; then
    return
  fi

  # local_max_total is used for bar scaling (per-block proportions)
  # max_total may be inflated by forced_max_total for consistent column layout
  local local_max_total="$max_total"
  if [ "$forced_max_total" -gt "$max_total" ]; then
    max_total="$forced_max_total"
  fi

  columns="$(terminal_columns)"
  available_width=$((columns - indent))
  if [ "$available_width" -lt 20 ]; then
    available_width=20
  fi

  if [ "$max_total" -gt 0 ]; then
    count_width=${#max_total}
  else
    count_width=1
  fi

  bar_width=$((available_width / 4))
  if [ "$bar_width" -lt 8 ]; then bar_width=8; fi
  if [ "$bar_width" -gt 25 ]; then bar_width=25; fi

  if [ "$FANCY_MODE" -eq 1 ]; then
    # fancy layout: path  bar  count  +add  -del  (2-space separators)
    add_col_width=$((count_width + 1))
    del_col_width=$((count_width + 1))
    path_width=$((available_width - 2 - bar_width - 2 - count_width - 2 - add_col_width - 2 - del_col_width))
    if [ "$path_width" -lt 12 ]; then
      path_width=12
      bar_width=$((available_width - path_width - 8 - count_width - add_col_width - del_col_width))
      if [ "$bar_width" -lt 0 ]; then bar_width=0; fi
    fi
  else
    # path | count_width bar_width  (with " | " and " " separators)
    path_width=$((available_width - 3 - count_width - 1 - bar_width))
    if [ "$path_width" -lt 12 ]; then
      path_width=12
      bar_width=$((available_width - path_width - 3 - count_width - 1))
      if [ "$bar_width" -lt 0 ]; then bar_width=0; fi
    fi
  fi

  local line display_path a r t bar_total add_chars remove_chars bar_str count_str
  local esc=$'\033'
  local total_fill empty_fill add_str del_str base_path
  for ((i = 0; i < count; i++)); do
    display_path="$(truncate_middle "${paths[$i]}" "$path_width")"
    if [ "${is_binary[$i]}" -eq 1 ]; then
      printf -v line "%-${path_width}s | Bin" "$display_path"
    else
      a="${added_list[$i]}"
      r="${removed_list[$i]}"
      t=$((a + r))
      add_chars=0
      remove_chars=0
      if [ "$local_max_total" -gt 0 ] && [ "$bar_width" -gt 0 ]; then
        bar_total=$(( (t * bar_width + local_max_total / 2) / local_max_total ))
        if [ "$bar_total" -lt 1 ] && [ "$t" -gt 0 ]; then bar_total=1; fi
        if [ "$t" -gt 0 ]; then
          add_chars=$(( (a * bar_total + t / 2) / t ))
          remove_chars=$((bar_total - add_chars))
        fi
      fi
      if [ "$FANCY_MODE" -eq 1 ]; then
        total_fill=$((add_chars + remove_chars))
        empty_fill=$((bar_width - total_fill))
        bar_str="$(make_block_diff_bar "$add_chars" "$remove_chars" "$empty_fill")"
        printf -v count_str "%${count_width}d" "$t"
        printf -v add_str "%${add_col_width}s" "+${a}"
        printf -v del_str "%${del_col_width}s" "-${r}"
        printf -v base_path "%-${path_width}s" "$display_path"
        if [ "$ENABLE_COLOR" -eq 1 ]; then
          line="${base_path}  ${bar_str}  ${count_str}  ${esc}[32m${add_str}${esc}[0m  ${esc}[31m${del_str}${esc}[0m"
        else
          line="${base_path}  ${bar_str}  ${count_str}  ${add_str}  ${del_str}"
        fi
      else
        bar_str="$(make_diff_bar "$add_chars" "$remove_chars")"
        printf -v count_str "%${count_width}d" "$t"
        printf -v line "%-${path_width}s | %s " "$display_path" "$count_str"
        line="${line}${bar_str}"
      fi
    fi
    if [ -n "$result" ]; then
      result="${result}"$'\n'
    fi
    result="${result}${line}"
  done

  if [ "$count" -eq 1 ]; then
    file_word="file"
  fi

  local total_label="total: ${count} ${file_word}"
  local total_count=$((total_added + total_removed))
  local total_count_str breakdown summary
  printf -v total_count_str "%${count_width}d" "$total_count"
  breakdown="+${total_added}/-${total_removed}"
  if [ "$binary_count" -gt 0 ]; then
    breakdown="${breakdown}, ${binary_count} binary"
  fi
  if [ "$FANCY_MODE" -eq 1 ]; then
    local bar_pad
    printf -v bar_pad '%*s' "$bar_width" ''
    printf -v summary "%-${path_width}s  %s  %s  %s" "$total_label" "$bar_pad" "$total_count_str" "$breakdown"
  else
    printf -v summary "%-${path_width}s | %s  %s" "$total_label" "$total_count_str" "$breakdown"
  fi

  printf '%s\n%s' "$result" "$summary"
}

collect_git_unborn_worktree_numstat() {
  local root="$1"
  local tmp_dir="" tmp_index=""
  local detail=""

  tmp_dir="$(make_temp_dir)" || {
    printf '%s' "$(git -C "$root" diff --cached --numstat --root 2>/dev/null || true)"
    return
  }

  tmp_index="$tmp_dir/index"
  : >"$tmp_index"

  if GIT_INDEX_FILE="$tmp_index" git -C "$root" add -A -- . >/dev/null 2>&1; then
    detail="$(GIT_INDEX_FILE="$tmp_index" git -C "$root" diff --cached --numstat --root 2>/dev/null || true)"
  else
    detail="$(git -C "$root" diff --cached --numstat --root 2>/dev/null || true)"
  fi

  rm -rf "$tmp_dir"
  printf '%s' "$detail"
}

collect_jj_stat_tsv() {
  local root="$1"
  local revset="$2"
  jj -R "$root" log -r "$revset" --no-graph -T 'diff.stat().files().map(|f| f.lines_added() ++ "\t" ++ f.lines_removed() ++ "\t" ++ f.display_diff_path() ++ "\n")' 2>/dev/null || true
}

build_jj_commit_detail() {
  local root="$1"
  local revset="$2"
  local raw line current_title current_stats result=""
  local tab=$'\t'
  local commit_titles=() commit_stats_list=()

  raw="$(jj -R "$root" log -r "$revset" --reversed --no-graph -T '"__COMMIT__\t" ++ commit_id.short() ++ "\t" ++ description.first_line() ++ "\n" ++ diff.stat().files().map(|f| f.lines_added() ++ "\t" ++ f.lines_removed() ++ "\t" ++ f.display_diff_path() ++ "\n") ++ "__END__\n"' 2>/dev/null || true)"
  raw="$(trim_trailing_newlines "$raw")"
  if [ -z "$raw" ]; then
    return
  fi

  # Pass 1: collect (title, raw_tsv) pairs
  current_title=""
  current_stats=""
  while IFS= read -r line; do
    [ -n "$line" ] || continue
    if [ "$line" = "__END__" ]; then
      if [ -n "$current_title" ]; then
        commit_titles+=("$current_title")
        commit_stats_list+=("$current_stats")
      fi
      current_title=""
      current_stats=""
    elif [ "${line%%"$tab"*}" = "__COMMIT__" ]; then
      line="${line#__COMMIT__"$tab"}"
      current_title="${line%%"$tab"*}"
      if [ "$line" != "${line#*"$tab"}" ]; then
        line="${line#*"$tab"}"
        if [ -n "$line" ]; then
          current_title="${current_title} ${line}"
        fi
      fi
      current_stats=""
    else
      if [ -n "$current_stats" ]; then
        current_stats="${current_stats}"$'\n'"$line"
      else
        current_stats="$line"
      fi
    fi
  done <<EOF
$raw
EOF

  if [ "${#commit_titles[@]}" -eq 0 ]; then
    return
  fi

  # Serialize as __C__\t{title}\n{tsv}\n__E__ — formatting is deferred to render time
  local i
  for ((i = 0; i < ${#commit_titles[@]}; i++)); do
    if [ -n "$result" ]; then
      result="${result}"$'\n'
    fi
    result="${result}__C__${tab}${commit_titles[$i]}"
    if [ -n "${commit_stats_list[$i]}" ]; then
      result="${result}"$'\n'"${commit_stats_list[$i]}"
    fi
    result="${result}"$'\n'"__E__"
  done

  printf '%s' "$result"
}

collect_git_work_state() {
  local idx="$1"
  local root="$2"
  local porcelain
  if ! porcelain="$(git -C "$root" status --porcelain=v1 --untracked-files=normal 2>&1)"; then
    warn "Git working-copy check failed for $root: $(first_nonempty_line "$porcelain")"
    set_work_status "$idx" "error" "!! scan error" "$(first_nonempty_line "$porcelain")"
    return
  fi

  local modified=0
  local untracked=0
  local untracked_list=""
  local line path
  while IFS= read -r line; do
    [ -z "$line" ] && continue
    if [ "${line#\?\? }" != "$line" ]; then
      untracked=$((untracked + 1))
      if [ "$COLLECT_DETAIL_DATA" -eq 1 ]; then
        path="${line#\?\? }"
        if [ -n "$untracked_list" ]; then
          untracked_list="${untracked_list}"$'\n'"$path"
        else
          untracked_list="$path"
        fi
      fi
    else
      modified=$((modified + 1))
    fi
  done <<EOF
$porcelain
EOF

  local display
  display="$(join_counts "$modified" "$untracked")"

  local detail=""
  if [ "$COLLECT_DETAIL_DATA" -eq 1 ] && [ "$modified" -gt 0 ]; then
    local has_head=1
    if ! git -C "$root" rev-parse --verify HEAD >/dev/null 2>&1; then
      has_head=0
    fi

    if [ "$has_head" -eq 1 ]; then
      detail="$(git -C "$root" diff HEAD --numstat 2>/dev/null || true)"
    else
      detail="$(collect_git_unborn_worktree_numstat "$root")"
    fi
  fi

  if [ "$modified" -gt 0 ] || [ "$untracked" -gt 0 ]; then
    set_work_status "$idx" "changes" "$display" "" "$detail" "$untracked_list"
  else
    set_work_status "$idx" "clean" "- clean"
  fi
}

collect_git_state() {
  local idx="$1"
  local root="$2"
  local status_output

  if ! status_output="$(git -C "$root" status --porcelain=v2 --branch --untracked-files=normal 2>&1)"; then
    warn "Git state check failed for $root: $(first_nonempty_line "$status_output")"
    set_push_status "$idx" "error" "!! scan error" "$(first_nonempty_line "$status_output")"
    set_work_status "$idx" "error" "!! scan error" "$(first_nonempty_line "$status_output")"
    return
  fi

  # Parse branch header lines
  local oid="" head_branch="" upstream="" ahead=0 behind=0 has_upstream=0
  local ab line
  while IFS= read -r line; do
    case "$line" in
      "# branch.oid "*)      oid="${line#'# branch.oid '}" ;;
      "# branch.head "*)     head_branch="${line#'# branch.head '}" ;;
      "# branch.upstream "*) upstream="${line#'# branch.upstream '}"; has_upstream=1 ;;
      "# branch.ab "*)
        ab="${line#'# branch.ab '}"
        ahead="${ab%% -*}"; ahead="${ahead#+}"
        behind="${ab##*-}"
        ;;
    esac
  done <<EOF
$status_output
EOF

  # --- Push state ---
  if [ "$oid" = "(initial)" ]; then
    set_push_status "$idx" "question" "? no commits" "repository has no commits yet"
  elif [ "$head_branch" = "(detached)" ]; then
    set_push_status "$idx" "question" "? detached HEAD" "detached HEAD — no upstream branch to compare"
  elif [ "$has_upstream" -eq 0 ]; then
    local remotes
    remotes="$(git -C "$root" remote 2>/dev/null || true)"
    if [ "$(count_nonempty_lines "$remotes")" -eq 0 ]; then
      set_push_status "$idx" "question" "? no remote" "no Git remote configured"
    else
      set_push_status "$idx" "question" "? no upstream" "no upstream configured for branch $head_branch"
    fi
  else
    local push_detail=""
    if [ "$COLLECT_DETAIL_DATA" -eq 1 ] && [ "$ahead" -gt 0 ]; then
      push_detail="$(build_git_outgoing_detail "$root" "$upstream")"
    fi
    if [ "$ahead" -gt 0 ] && [ "$behind" -gt 0 ]; then
      set_push_status "$idx" "diverged" "↕ ${ahead} ahead, ${behind} behind" "behind remote by ${behind} commit(s)" "$push_detail"
    elif [ "$ahead" -gt 0 ]; then
      set_push_status "$idx" "outgoing" "↑ ${ahead} outgoing" "" "$push_detail"
    elif [ "$behind" -gt 0 ]; then
      set_push_status "$idx" "behind" "↓ ${behind} behind" "behind remote — pull required"
    else
      set_push_status "$idx" "clean" "- up to date"
    fi
  fi

  # --- Work state ---
  local modified=0 untracked=0 untracked_list="" path
  while IFS= read -r line; do
    [ -z "$line" ] && continue
    case "$line" in
      "# "*) ;;
      "? "*)
        untracked=$((untracked + 1))
        if [ "$COLLECT_DETAIL_DATA" -eq 1 ]; then
          path="${line#? }"
          if [ -n "$untracked_list" ]; then
            untracked_list="${untracked_list}"$'\n'"$path"
          else
            untracked_list="$path"
          fi
        fi
        ;;
      "1 "* | "2 "* | "u "*) modified=$((modified + 1)) ;;
    esac
  done <<EOF
$status_output
EOF

  local work_detail=""
  if [ "$COLLECT_DETAIL_DATA" -eq 1 ] && [ "$modified" -gt 0 ]; then
    if [ "$oid" = "(initial)" ]; then
      work_detail="$(collect_git_unborn_worktree_numstat "$root")"
    else
      work_detail="$(git -C "$root" diff HEAD --numstat 2>/dev/null || true)"
    fi
  fi

  local display
  display="$(join_counts "$modified" "$untracked")"
  if [ "$modified" -gt 0 ] || [ "$untracked" -gt 0 ]; then
    set_work_status "$idx" "changes" "$display" "" "$work_detail" "$untracked_list"
  else
    set_work_status "$idx" "clean" "- clean"
  fi
}

build_git_outgoing_detail() {
  local root="$1"
  local upstream="$2"
  local result="" tab=$'\t'
  local raw_log line current_hash="" current_stats=""

  # Single git log call: subject + numstat for all outgoing commits
  raw_log="$(git -C "$root" log --reverse --numstat --format="__C__${tab}%h  %s" "${upstream}..HEAD" 2>/dev/null || true)"
  if [ -z "$raw_log" ]; then
    return
  fi

  # Serialize as __C__\t{title}\n{tsv}\n__E__ — formatting is deferred to render time
  while IFS= read -r line; do
    case "$line" in
      "__C__${tab}"*)
        if [ -n "$current_hash" ]; then
          [ -n "$result" ] && result="${result}"$'\n'
          result="${result}__C__${tab}${current_hash}"
          [ -n "$current_stats" ] && result="${result}"$'\n'"$current_stats"
          result="${result}"$'\n'"__E__"
        fi
        current_hash="${line#"__C__${tab}"}"
        current_stats=""
        ;;
      "") ;;
      *)
        if [ -n "$current_stats" ]; then
          current_stats="${current_stats}"$'\n'"$line"
        else
          current_stats="$line"
        fi
        ;;
    esac
  done <<EOF
$raw_log
EOF

  if [ -n "$current_hash" ]; then
    [ -n "$result" ] && result="${result}"$'\n'
    result="${result}__C__${tab}${current_hash}"
    [ -n "$current_stats" ] && result="${result}"$'\n'"$current_stats"
    result="${result}"$'\n'"__E__"
  fi

  printf '%s' "$result"
}

jj_draft_revset() {
  printf 'reachable(@, mutable()) ~ ::bookmarks() ~ @'
}

collect_jj_drafts() {
  local root="$1"
  local output
  output="$(jj -R "$root" log -r "$(jj_draft_revset)" --no-graph -T 'change_id.short() ++ " " ++ description.first_line() ++ "\n"' 2>/dev/null || true)"
  output="$(trim_trailing_newlines "$output")"
  printf '%s' "$output"
}

count_jj_drafts() {
  local root="$1"
  local output
  output="$(jj -R "$root" log -r "$(jj_draft_revset)" --count 2>/dev/null || true)"
  first_nonempty_line "$output"
}

jj_outgoing_revset() {
  local remote="${1:-}"
  if [ -n "$remote" ]; then
    printf '::bookmarks() ~ ::remote_bookmarks(remote=%s)' "$remote"
  else
    printf '::bookmarks() ~ ::remote_bookmarks()'
  fi
}

count_jj_outgoing_commits() {
  local root="$1"
  local revset="$2"
  local output
  output="$(jj -R "$root" log -r "$revset" --count 2>/dev/null || true)"
  first_nonempty_line "$output"
}

collect_jj_work_state() {
  local idx="$1"
  local root="$2"
  local using_git="${3:-0}"

  if [ "$using_git" -eq 1 ]; then
    collect_git_work_state "$idx" "$root"
    return
  fi

  local status_output
  if ! status_output="$(jj -R "$root" status 2>&1)"; then
    warn "JJ working-copy check failed for $root: $(first_nonempty_line "$status_output")"
    set_work_status "$idx" "error" "!! scan error" "$(first_nonempty_line "$status_output")"
    return
  fi

  if contains_line "$status_output" "The working copy has no changes."; then
    set_work_status "$idx" "clean" "- clean"
    return
  fi

  local modified
  modified="$(jj -R "$root" diff --name-only 2>/dev/null | awk 'NF { count++ } END { print count + 0 }')"
  if [ -z "$modified" ]; then
    modified=0
  fi

  if [ "$modified" -gt 0 ]; then
    local detail=""
    if [ "$COLLECT_DETAIL_DATA" -eq 1 ]; then
      detail="$(collect_jj_stat_tsv "$root" '@')"
    fi
    set_work_status "$idx" "changes" "* ${modified} modified" "" "$detail"
  else
    set_work_status "$idx" "clean" "- clean"
  fi
}

build_jj_outgoing_detail() {
  local root="$1"
  local dry_run_output="$2"
  local result=""
  local line action bookmark summary

  while IFS= read -r line; do
    case "$line" in
    'Changes to push to '* | 'Dry-run requested, not pushing.')
      continue
      ;;
    '  '*)
      action="${line#  }"
      bookmark="$(printf '%s\n' "$action" | sed -E 's/.* bookmark ([^ ]+).*/\1/' 2>/dev/null)"
      if [ -n "$result" ]; then
        result="${result}"$'\n'
      fi
      result="${result}${action} (stat unavailable)"
      if [ -n "$bookmark" ] && [ "$bookmark" != "$action" ]; then
        summary="$(jj -R "$root" log -r "$bookmark" --no-graph -T 'description.first_line() ++ "\n"' 2>/dev/null | awk 'NF { print; exit }')"
        if [ -n "$summary" ]; then
          result="${result}"$'\n'"target: $summary"
        fi
      fi
      ;;
    esac
  done <<EOF
$dry_run_output
EOF

  printf '%s' "$result"
}

collect_jj_push_state() {
  local idx="$1"
  local root="$2"

  local draft_detail="" draft_count=""
  if [ "$COLLECT_DETAIL_DATA" -eq 1 ]; then
    draft_detail="$(collect_jj_drafts "$root")"
    draft_count="$(count_nonempty_lines "$draft_detail")"
    set_draft_detail "$idx" "$draft_detail"
  else
    draft_count="$(count_jj_drafts "$root")"
  fi
  if [ -z "$draft_count" ] || ! is_integer "$draft_count"; then
    draft_count=0
  fi

  local remote_output remote_count
  remote_output="$(jj -R "$root" git remote list 2>/dev/null || true)"
  remote_count="$(count_nonempty_lines "$remote_output")"
  if [ "$remote_count" -eq 0 ] && [ -z "$REMOTE_OVERRIDE" ]; then
    if [ "$draft_count" -gt 0 ]; then
      set_push_status "$idx" "draft" "~ ${draft_count} draft only" "draft commits are not pushable until bookmarked"
    else
      set_push_status "$idx" "question" "? no remote" "no JJ remote configured"
    fi
    return
  fi

  local jj_cmd
  jj_cmd=(jj -R "$root" git push --dry-run)
  if [ -n "$REMOTE_OVERRIDE" ]; then
    jj_cmd+=(--remote "$REMOTE_OVERRIDE")
  fi

  local dry_run_output status
  if command_exists timeout; then
    dry_run_output="$(timeout 30 "${jj_cmd[@]}" 2>&1)"
    status=$?
  else
    dry_run_output="$("${jj_cmd[@]}" 2>&1)"
    status=$?
  fi

  if [ "$status" -eq 124 ]; then
    warn "JJ push-state check timed out for $root"
    set_push_status "$idx" "push_failed" "! push check failed" "push check timed out after 30s"
    return
  fi

  if [ "$status" -ne 0 ]; then
    warn "JJ push-state check failed for $root: $(first_nonempty_line "$dry_run_output")"
    set_push_status "$idx" "push_failed" "! push check failed" "push check failed: $(first_nonempty_line "$dry_run_output")"
    return
  fi

  local action_count
  action_count="$(printf '%s\n' "$dry_run_output" | awk '
    BEGIN { in_actions = 0; count = 0 }
    /^Changes to push to / { in_actions = 1; next }
    /^Dry-run requested, not pushing\./ { in_actions = 0 }
    in_actions && /^  / { count++ }
    END { print count + 0 }
  ')"

  local detail=""
  if [ "$action_count" -gt 0 ]; then
    local selected_remote outgoing_count outgoing_revset commit_detail
    selected_remote="$(printf '%s\n' "$dry_run_output" | awk '
      /^Changes to push to / {
        line = $0
        sub(/^Changes to push to /, "", line)
        sub(/:$/, "", line)
        print line
        exit
      }
    ')"
    outgoing_revset="$(jj_outgoing_revset "$selected_remote")"
    outgoing_count="$(count_jj_outgoing_commits "$root" "$outgoing_revset")"
    if [ -z "$outgoing_count" ] || ! is_integer "$outgoing_count" || [ "$outgoing_count" -eq 0 ]; then
      outgoing_count="$action_count"
    fi
    if [ "$COLLECT_DETAIL_DATA" -eq 1 ]; then
      commit_detail="$(build_jj_commit_detail "$root" "$outgoing_revset")"
      if [ -n "$commit_detail" ]; then
        detail="$commit_detail"
      else
        detail="$(build_jj_outgoing_detail "$root" "$dry_run_output")"
      fi
    fi
    if [ "$draft_count" -gt 0 ]; then
      set_push_status "$idx" "outgoing" "↑ ${outgoing_count} outgoing (+${draft_count} draft)" "" "$detail"
    else
      set_push_status "$idx" "outgoing" "↑ ${outgoing_count} outgoing" "" "$detail"
    fi
    return
  fi

  if contains_line "$dry_run_output" "Refusing to create new remote bookmark"; then
    set_push_status "$idx" "question" "? no tracked bookmarks" "local bookmarks are not tracked on the selected remote"
    return
  fi

  if [ "$draft_count" -gt 0 ]; then
    set_push_status "$idx" "draft" "~ ${draft_count} draft only" "draft commits are not pushable until bookmarked"
    return
  fi

  set_push_status "$idx" "clean" "- up to date"
}

collect_repo_state() {
  local idx="$1"
  local root="${REPO_ROOTS[$idx]}"
  local type="${REPO_TYPES[$idx]}"
  local has_git_checkout=0

  if [ "$type" = "git" ]; then
    if [ "$HAVE_GIT" -ne 1 ]; then
      set_push_status "$idx" "unavailable" "!! git unavailable" "git is not installed"
      set_work_status "$idx" "unavailable" "!! git unavailable" "git is not installed"
      return
    fi

    collect_git_state "$idx" "$root"
    return
  fi

  if [ "$HAVE_JJ" -ne 1 ]; then
    set_push_status "$idx" "unavailable" "!! jj unavailable" "jj is not installed"
    set_work_status "$idx" "unavailable" "!! jj unavailable" "jj is not installed"
    return
  fi

  if [ -e "$root/.git" ]; then
    has_git_checkout=1
  fi

  collect_jj_push_state "$idx" "$root"
  if [ "$has_git_checkout" -eq 1 ] && [ "$HAVE_GIT" -eq 1 ]; then
    collect_jj_work_state "$idx" "$root" 1
  else
    collect_jj_work_state "$idx" "$root" 0
  fi
}

write_repo_state() {
  local idx="$1"
  printf 'REPO_PUSH_KIND[%s]=%q\n' "$idx" "${REPO_PUSH_KIND[$idx]}"
  printf 'REPO_PUSH_PLAIN[%s]=%q\n' "$idx" "${REPO_PUSH_PLAIN[$idx]}"
  printf 'REPO_PUSH_NOTE[%s]=%q\n' "$idx" "${REPO_PUSH_NOTE[$idx]}"
  printf 'REPO_PUSH_DETAIL[%s]=%q\n' "$idx" "${REPO_PUSH_DETAIL[$idx]}"
  printf 'REPO_WORK_KIND[%s]=%q\n' "$idx" "${REPO_WORK_KIND[$idx]}"
  printf 'REPO_WORK_PLAIN[%s]=%q\n' "$idx" "${REPO_WORK_PLAIN[$idx]}"
  printf 'REPO_WORK_NOTE[%s]=%q\n' "$idx" "${REPO_WORK_NOTE[$idx]}"
  printf 'REPO_WORK_DETAIL[%s]=%q\n' "$idx" "${REPO_WORK_DETAIL[$idx]}"
  printf 'REPO_UNTRACKED_DETAIL[%s]=%q\n' "$idx" "${REPO_UNTRACKED_DETAIL[$idx]}"
  printf 'REPO_DRAFT_DETAIL[%s]=%q\n' "$idx" "${REPO_DRAFT_DETAIL[$idx]}"
}

load_repo_state() {
  local idx="$1"
  local state_file="$2"
  if [ ! -f "$state_file" ]; then
    warn "Parallel state collection failed for ${REPO_ROOTS[$idx]}"
    set_push_status "$idx" "error" "!! scan error" "parallel state collection failed"
    set_work_status "$idx" "error" "!! scan error" "parallel state collection failed"
    return
  fi

  # shellcheck source=/dev/null
  . "$state_file"
}

emit_repo_warnings() {
  local err_file="$1"
  if [ -s "$err_file" ]; then
    cat "$err_file" >&2
  fi
}

collect_all_repo_states() {
  local repo_count="${#REPO_ROOTS[@]}"
  local jobs="$PARALLEL_JOBS"
  local i

  if [ "$repo_count" -eq 0 ]; then
    return
  fi

  if [ "$jobs" -le 1 ] || [ "$repo_count" -le 1 ]; then
    for ((i = 0; i < repo_count; i++)); do
      collect_repo_state "$i"
    done
    return
  fi

  STATE_TMP_DIR="$(make_temp_dir)" || die "failed to create temporary directory for parallel state collection"

  # FIFO-based semaphore: keeps exactly $jobs workers running at all times.
  # Unlike fixed batches, a slow repo doesn't stall the next batch from starting.
  local sem_fifo="$STATE_TMP_DIR/sem"
  mkfifo "$sem_fifo"
  exec 3<>"$sem_fifo"
  for ((i = 0; i < jobs; i++)); do
    printf 'x' >&3
  done

  local pids=() idx state_file err_file
  for ((idx = 0; idx < repo_count; idx++)); do
    read -r -n 1 -u 3  # acquire a slot; blocks when all $jobs slots are taken
    state_file="$STATE_TMP_DIR/repo.$idx.state"
    err_file="$STATE_TMP_DIR/repo.$idx.err"
    (
      trap 'printf "x" >&3' EXIT  # release slot on exit, even on error
      collect_repo_state "$idx" >/dev/null
      write_repo_state "$idx" >"$state_file"
    ) 2>"$err_file" &
    pids+=("$!")
  done

  for pid in "${pids[@]}"; do
    wait "$pid"
  done
  exec 3>&-

  for ((idx = 0; idx < repo_count; idx++)); do
    state_file="$STATE_TMP_DIR/repo.$idx.state"
    err_file="$STATE_TMP_DIR/repo.$idx.err"
    load_repo_state "$idx" "$state_file"
    emit_repo_warnings "$err_file"
  done
}

repo_error_count() {
  local idx="$1"
  case "${REPO_PUSH_KIND[$idx]}:${REPO_WORK_KIND[$idx]}" in
  *error* | *unavailable*)
    printf '1'
    ;;
  *)
    printf '0'
    ;;
  esac
}

should_show_repo() {
  local idx="$1"
  if [ "$DIRTY_ONLY" -eq 0 ]; then
    return 0
  fi
  if is_repo_clean "$idx"; then
    return 1
  fi
  return 0
}

# Pad STR to visual width TARGET, storing result in RESULT_VAR.
# bash printf "%-Ns" counts N as bytes, but ${#s} gives char count in UTF-8 locale.
# This helper compensates so multi-byte chars (e.g. ↓ ↑ ↕) don't break alignment.
pad_to_visual() {
  local _str="$1" _target="$2" _var="$3"
  local _char_len _byte_len _extra
  _char_len=${#_str}
  local LC_ALL=C
  _byte_len=${#_str}
  _extra=$((_byte_len - _char_len))
  printf -v "$_var" "%-$((_target + _extra))s" "$_str"
}

print_default_view() {
  local shown_indices=()
  local -a cached_paths=()
  local i path_plain type_plain push_plain work_plain
  local max_path=0 max_type=0 max_push=0 max_work=0
  for ((i = 0; i < ${#REPO_ROOTS[@]}; i++)); do
    if ! should_show_repo "$i"; then
      continue
    fi
    shown_indices+=("$i")
    path_plain="$(display_path "${REPO_ROOTS[$i]}")"
    cached_paths[$i]="$path_plain"
    type_plain="[${REPO_TYPES[$i]}]"
    push_plain="${REPO_PUSH_PLAIN[$i]}"
    work_plain="${REPO_WORK_PLAIN[$i]}"
    [ "${#path_plain}" -gt "$max_path" ] && max_path="${#path_plain}"
    [ "${#type_plain}" -gt "$max_type" ] && max_type="${#type_plain}"
    [ "${#push_plain}" -gt "$max_push" ] && max_push="${#push_plain}"
    [ "${#work_plain}" -gt "$max_work" ] && max_work="${#work_plain}"
  done

  if [ "${#shown_indices[@]}" -eq 0 ]; then
    return
  fi

  local padded_path padded_type padded_push padded_work
  for i in "${shown_indices[@]}"; do
    path_plain="${cached_paths[$i]}"
    type_plain="[${REPO_TYPES[$i]}]"
    push_plain="${REPO_PUSH_PLAIN[$i]}"
    work_plain="${REPO_WORK_PLAIN[$i]}"
    printf -v padded_path "%-${max_path}s" "$path_plain"
    printf -v padded_type "%-${max_type}s" "$type_plain"
    pad_to_visual "$push_plain" "$max_push" padded_push
    pad_to_visual "$work_plain" "$max_work" padded_work
    if [ "$FANCY_MODE" -eq 1 ] && [ "$ENABLE_COLOR" -eq 1 ]; then
      printf '\033[2m%s\033[0m  \033[2m%s\033[0m  %s  \033[2m|\033[0m  %s\n' \
        "$padded_path" \
        "$padded_type" \
        "$(colorize_status "${REPO_PUSH_KIND[$i]}" "$padded_push")" \
        "$(colorize_status "${REPO_WORK_KIND[$i]}" "$padded_work")"
    else
      printf '%s  %s  %s  |  %s\n' \
        "$padded_path" \
        "$padded_type" \
        "$(colorize_status "${REPO_PUSH_KIND[$i]}" "$padded_push")" \
        "$(colorize_status "${REPO_WORK_KIND[$i]}" "$padded_work")"
    fi
  done
}

format_commit_raw_data() {
  local raw_data="$1"
  local global_max_total="${2:-0}"
  local result="" line title cur_tsv="" in_commit=0
  local dline indented_detail detail
  local tab=$'\t'

  while IFS= read -r line; do
    case "$line" in
    "__C__${tab}"*)
      title="${line#"__C__${tab}"}"
      cur_tsv=""
      in_commit=1
      ;;
    "__E__")
      if [ "$in_commit" -eq 1 ]; then
        detail="$(format_compact_stat_tsv "$cur_tsv" 7 "$global_max_total")"
        if [ -n "$result" ]; then
          result="${result}"$'\n'$'\n'
        fi
        result="${result}${title}"
        if [ -n "$detail" ]; then
          indented_detail=""
          while IFS= read -r dline; do
            [ -n "$dline" ] || continue
            [ -n "$indented_detail" ] && indented_detail="${indented_detail}"$'\n'
            indented_detail="${indented_detail}  ${dline}"
          done <<EOF
$detail
EOF
          result="${result}"$'\n'"$indented_detail"
        fi
      fi
      in_commit=0
      cur_tsv=""
      ;;
    *)
      if [ "$in_commit" -eq 1 ]; then
        [ -n "$cur_tsv" ] && cur_tsv="${cur_tsv}"$'\n'"$line" || cur_tsv="$line"
      fi
      ;;
    esac
  done <<EOF
$raw_data
EOF

  printf '%s' "$result"
}

print_multiline_block() {
  local block="$1"
  local indent="${2:-5}"
  local pad line
  printf -v pad '%*s' "$indent" ''
  while IFS= read -r line; do
    if [ -z "$line" ]; then
      printf '\n'
    else
      printf '%s%s\n' "$pad" "$line"
    fi
  done <<EOF
$block
EOF
}

print_repo_header_line() {
  local label="$1"
  local cols prefix fill dashes i
  cols="$(terminal_columns)"
  if [ "$FANCY_MODE" -eq 1 ]; then
    prefix="${label} "
    fill=$((cols - ${#prefix}))
    dashes=""
    if [ "$fill" -gt 0 ]; then
      for ((i = 0; i < fill; i++)); do dashes="${dashes}─"; done
    fi
    if [ "$ENABLE_COLOR" -eq 1 ]; then
      printf '\033[1m%s\033[0m\033[2m%s\033[0m\n' "$prefix" "$dashes"
    else
      printf '%s%s\n' "$prefix" "$dashes"
    fi
  else
    prefix="-- ${label} "
    fill=$((cols - ${#prefix}))
    dashes=""
    if [ "$fill" -gt 0 ]; then
      dashes="$(repeat_char '-' "$fill")"
    fi
    if [ "$ENABLE_COLOR" -eq 1 ]; then
      printf '\033[1m%s%s\033[0m\n' "$prefix" "$dashes"
    else
      printf '%s%s\n' "$prefix" "$dashes"
    fi
  fi
}

print_section_label() {
  local kind="$1"
  local symbol="$2"
  local text="$3"
  local color
  if [ "$ENABLE_COLOR" -eq 1 ]; then
    color="$(status_color "$kind")"
    if [ -n "$color" ]; then
      printf '   %b%s %s%b\n' "$color" "$symbol" "$text" '\033[0m'
      return
    fi
  fi
  printf '   %s %s\n' "$symbol" "$text"
}

max_total_from_commit_raw_data() {
  local raw_data="$1"
  local max=0 block_max line cur_tsv="" in_commit=0
  local tab=$'\t'
  while IFS= read -r line; do
    case "$line" in
    "__C__${tab}"*) cur_tsv=""; in_commit=1 ;;
    "__E__")
      if [ "$in_commit" -eq 1 ] && [ -n "$cur_tsv" ]; then
        block_max="$(tsv_max_total "$cur_tsv")"
        [ "$block_max" -gt "$max" ] && max="$block_max"
      fi
      in_commit=0; cur_tsv="" ;;
    *)
      if [ "$in_commit" -eq 1 ]; then
        [ -n "$cur_tsv" ] && cur_tsv="${cur_tsv}"$'\n'"$line" || cur_tsv="$line"
      fi ;;
    esac
  done <<EOF
$raw_data
EOF
  printf '%s' "$max"
}

print_detail_view() {
  local shown_indices=()
  local i
  for ((i = 0; i < ${#REPO_ROOTS[@]}; i++)); do
    if ! should_show_repo "$i"; then
      continue
    fi
    shown_indices+=("$i")
  done

  if [ "${#shown_indices[@]}" -eq 0 ]; then
    return
  fi

  # Pass 2: scan all repos to find global max_total for consistent column alignment
  local global_max_total=0 block_max
  local tab=$'\t'
  for i in "${shown_indices[@]}"; do
    case "${REPO_PUSH_DETAIL[$i]}" in
    "__C__${tab}"*)
      block_max="$(max_total_from_commit_raw_data "${REPO_PUSH_DETAIL[$i]}")"
      [ "$block_max" -gt "$global_max_total" ] && global_max_total="$block_max"
      ;;
    esac
    if [ -n "${REPO_WORK_DETAIL[$i]}" ]; then
      block_max="$(tsv_max_total "${REPO_WORK_DETAIL[$i]}")"
      [ "$block_max" -gt "$global_max_total" ] && global_max_total="$block_max"
    fi
  done

  # Pass 3: format and print each repo using the global layout
  local first=1
  local push_kind work_kind label formatted
  for i in "${shown_indices[@]}"; do
    [ "$first" -eq 1 ] || printf '\n'
    first=0
    label="$(display_path "${REPO_ROOTS[$i]}")  [${REPO_TYPES[$i]}]"
    print_repo_header_line "$label"
    if [ "$FANCY_MODE" -eq 1 ] && [ "$ENABLE_COLOR" -eq 1 ]; then
      printf '   \033[2mpush:\033[0m  %s\n' "$(colorize_status "${REPO_PUSH_KIND[$i]}" "${REPO_PUSH_PLAIN[$i]}")"
      printf '   \033[2mwork:\033[0m  %s\n' "$(colorize_status "${REPO_WORK_KIND[$i]}" "${REPO_WORK_PLAIN[$i]}")"
    else
      printf '   push:  %s\n' "$(colorize_status "${REPO_PUSH_KIND[$i]}" "${REPO_PUSH_PLAIN[$i]}")"
      printf '   work:  %s\n' "$(colorize_status "${REPO_WORK_KIND[$i]}" "${REPO_WORK_PLAIN[$i]}")"
    fi

    push_kind="${REPO_PUSH_KIND[$i]}"
    work_kind="${REPO_WORK_KIND[$i]}"

    if [ -n "${REPO_PUSH_DETAIL[$i]}" ]; then
      printf '\n'
      print_section_label "outgoing" "↑" "Outgoing"
      case "${REPO_PUSH_DETAIL[$i]}" in
      "__C__${tab}"*)
        formatted="$(format_commit_raw_data "${REPO_PUSH_DETAIL[$i]}" "$global_max_total")"
        print_multiline_block "$formatted" 5
        ;;
      *)
        print_multiline_block "${REPO_PUSH_DETAIL[$i]}" 5
        ;;
      esac
      if [ "$push_kind" = "diverged" ] && [ -n "${REPO_PUSH_NOTE[$i]}" ]; then
        printf '   Note: %s\n' "${REPO_PUSH_NOTE[$i]}"
      fi
    elif [ -n "${REPO_PUSH_NOTE[$i]}" ]; then
      printf '   Note: %s\n' "${REPO_PUSH_NOTE[$i]}"
    fi

    if [ -n "${REPO_DRAFT_DETAIL[$i]}" ]; then
      printf '\n'
      print_section_label "draft" "~" "Drafts"
      print_multiline_block "${REPO_DRAFT_DETAIL[$i]}" 5
      printf '     not pushable until bookmarked\n'
    fi

    if [ -n "${REPO_WORK_DETAIL[$i]}" ]; then
      printf '\n'
      print_section_label "changes" "*" "Working copy"
      formatted="$(format_compact_stat_tsv "${REPO_WORK_DETAIL[$i]}" 5 "$global_max_total")"
      print_multiline_block "$formatted" 5
    fi

    if [ -n "${REPO_UNTRACKED_DETAIL[$i]}" ]; then
      printf '\n'
      print_section_label "question" "?" "Untracked"
      print_multiline_block "${REPO_UNTRACKED_DETAIL[$i]}" 5
    fi

    if [ "$work_kind" = "error" ] || [ "$work_kind" = "unavailable" ]; then
      if [ -n "${REPO_WORK_NOTE[$i]}" ]; then
        printf '   Note: %s\n' "${REPO_WORK_NOTE[$i]}"
      fi
    fi
  done
}

compute_summary() {
  local _i _out=0 _dirty=0 _errs=0
  for ((_i = 0; _i < ${#REPO_ROOTS[@]}; _i++)); do
    case "${REPO_PUSH_KIND[$_i]}" in
    outgoing | diverged) _out=$((_out + 1)) ;;
    esac
    case "${REPO_WORK_KIND[$_i]}" in
    changes) _dirty=$((_dirty + 1)) ;;
    esac
    case "${REPO_PUSH_KIND[$_i]}:${REPO_WORK_KIND[$_i]}" in
    *error* | *unavailable*) _errs=$((_errs + 1)) ;;
    esac
  done
  printf -v "$1" '%d' "$_out"
  printf -v "$2" '%d' "$_dirty"
  printf -v "$3" '%d' "$_errs"
}

print_json_view() {
  local i repo_count="${#REPO_ROOTS[@]}"
  local outgoing local_changes errors
  compute_summary outgoing local_changes errors

  printf '{\n'
  printf '  "repos": [\n'
  local first=1 je
  for ((i = 0; i < repo_count; i++)); do
    if ! should_show_repo "$i"; then
      continue
    fi
    local path_plain
    path_plain="$(display_path "${REPO_ROOTS[$i]}")"
    [ "$first" -eq 0 ] && printf ',\n'
    first=0
    printf '    {\n'
    json_escape je "$path_plain";             printf '      "path": "%s",\n' "$je"
    json_escape je "${REPO_TYPES[$i]}";       printf '      "type": "%s",\n' "$je"
    printf '      "push": {\n'
    json_escape je "${REPO_PUSH_KIND[$i]}";   printf '        "kind": "%s",\n' "$je"
    json_escape je "${REPO_PUSH_PLAIN[$i]}";  printf '        "text": "%s",\n' "$je"
    json_escape je "${REPO_PUSH_NOTE[$i]}";   printf '        "note": "%s"' "$je"
    if [ "$DETAIL_MODE" -eq 1 ]; then
      printf ',\n        "detail": '
      if [[ "${REPO_PUSH_DETAIL[$i]}" == __C__$'\t'* ]]; then
        print_json_commit_detail_array "        " "${REPO_PUSH_DETAIL[$i]}"
      else
        print_json_string_array "        " "${REPO_PUSH_DETAIL[$i]}"
      fi
      printf ',\n        "drafts": '
      print_json_string_array "        " "${REPO_DRAFT_DETAIL[$i]}"
    fi
    printf '\n      },\n'
    printf '      "work": {\n'
    json_escape je "${REPO_WORK_KIND[$i]}";   printf '        "kind": "%s",\n' "$je"
    json_escape je "${REPO_WORK_PLAIN[$i]}";  printf '        "text": "%s",\n' "$je"
    json_escape je "${REPO_WORK_NOTE[$i]}";   printf '        "note": "%s"' "$je"
    if [ "$DETAIL_MODE" -eq 1 ]; then
      printf ',\n        "detail": '
      print_json_numstat_array "        " "${REPO_WORK_DETAIL[$i]}"
      printf ',\n        "untracked": '
      print_json_string_array "        " "${REPO_UNTRACKED_DETAIL[$i]}"
    fi
    printf '\n      }\n'
    printf '    }'
  done
  printf '\n  ],\n'
  printf '  "summary": {\n'
  printf '    "scanned": %d,\n' "$repo_count"
  printf '    "outgoing": %d,\n' "$outgoing"
  printf '    "dirty": %d,\n' "$local_changes"
  printf '    "errors": %d\n' "$errors"
  printf '  }\n'
  printf '}\n'
}

print_summary() {
  local repo_count="${#REPO_ROOTS[@]}"
  local outgoing local_changes errors
  compute_summary outgoing local_changes errors

  local line="scanned: ${repo_count}  outgoing: ${outgoing}  dirty: ${local_changes}"
  if [ "$errors" -gt 0 ]; then
    line="${line}  errors: ${errors}"
  fi
  local divider=""
  while [ "${#divider}" -lt "${#line}" ]; do
    divider="${divider}-"
  done
  printf '\n%s\n%s\n%s\n' "$divider" "$line" "$divider"
}

check_exit_status() {
  local i
  if [ "$CHECK_MODE" -ne 1 ]; then
    return 0
  fi
  for ((i = 0; i < ${#REPO_ROOTS[@]}; i++)); do
    case "${REPO_PUSH_KIND[$i]}" in
    outgoing | behind | diverged | question | draft | push_failed | error | unavailable)
      return 1
      ;;
    esac
    case "${REPO_WORK_KIND[$i]}" in
    changes | error | unavailable)
      return 1
      ;;
    esac
  done
  return 0
}

parse_args() {
  while [ "$#" -gt 0 ]; do
    case "$1" in
    -d | --dirty)
      DIRTY_ONLY=1
      ;;
    -n | --depth)
      [ "$#" -ge 2 ] || die "--depth requires a value"
      MAX_DEPTH="$2"
      is_integer "$MAX_DEPTH" || die "--depth requires a non-negative integer"
      shift
      ;;
    -c | --check)
      CHECK_MODE=1
      ;;
    -r | --remote)
      [ "$#" -ge 2 ] || die "--remote requires a value"
      REMOTE_OVERRIDE="$2"
      shift
      ;;
    -j | --jobs)
      [ "$#" -ge 2 ] || die "--jobs requires a value"
      PARALLEL_JOBS="$2"
      is_integer "$PARALLEL_JOBS" || die "--jobs requires a positive integer"
      [ "$PARALLEL_JOBS" -ge 1 ] || die "--jobs requires a positive integer"
      shift
      ;;
    -e | --exclude)
      [ "$#" -ge 2 ] || die "--exclude requires a value"
      EXCLUDE_PATTERNS+=("$2")
      shift
      ;;
    -o | --output)
      [ "$#" -ge 2 ] || die "--output requires a value"
      OUTPUT="$2"
      case "$OUTPUT" in
      json | fancy | no-color) ;;
      *) die "unsupported output: $OUTPUT (supported: json, fancy, no-color)" ;;
      esac
      shift
      ;;
    -D | --detail)
      DETAIL_MODE=1
      ;;
    -h | --help)
      usage
      exit 0
      ;;
    --)
      shift
      break
      ;;
    -*)
      die "unknown option: $1"
      ;;
    *)
      SCAN_ROOTS+=("$1")
      ;;
    esac
    shift
  done
}

main() {
  parse_args "$@"
  trap cleanup_temp_state EXIT

  if [ "${#SCAN_ROOTS[@]}" -eq 0 ]; then
    SCAN_ROOTS=(".")
  fi
  local _root _canon
  for _root in "${SCAN_ROOTS[@]}"; do
    [ -d "$_root" ] || die "directory does not exist: $_root"
    _canon="$(canonicalize_dir "$_root" 2>/dev/null || true)"
    [ -n "$_canon" ] || die "failed to resolve scan root: $_root"
    SCAN_ROOT_CANONS+=("$_canon")
  done

  if command_exists git; then
    HAVE_GIT=1
  fi
  if command_exists jj; then
    HAVE_JJ=1
  fi
  if command_exists fd; then
    FD_CMD="fd"
  elif command_exists fdfind; then
    FD_CMD="fdfind"
  fi
  if [ "$HAVE_GIT" -eq 0 ] && [ "$HAVE_JJ" -eq 0 ]; then
    die "neither git nor jj is available"
  fi

  local no_color_flag=0 fancy_mode=0
  case "$OUTPUT" in
  no-color) no_color_flag=1 ;;
  fancy) fancy_mode=1 ;;
  esac

  if [ "$no_color_flag" -eq 0 ] && [ -z "${NO_COLOR:-}" ] && [ -t 1 ]; then
    ENABLE_COLOR=1
  fi
  FANCY_MODE="$fancy_mode"
  COLLECT_DETAIL_DATA="$DETAIL_MODE"
  if [ -z "$PARALLEL_JOBS" ]; then
    PARALLEL_JOBS="$(default_parallel_jobs)"
  fi

  for _canon in "${SCAN_ROOT_CANONS[@]}"; do
    discover_repos "$_canon"
  done
  sort_repos

  collect_all_repo_states

  if [ "$OUTPUT" = "json" ]; then
    ENABLE_COLOR=0
    print_json_view
  elif [ "$DETAIL_MODE" -eq 1 ]; then
    print_detail_view
    print_summary
  else
    print_default_view
    print_summary
  fi

  if check_exit_status; then
    exit 0
  fi
  exit 1
}

main "$@"
