#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(
  cd "$(dirname "${BASH_SOURCE[0]}")/.." 2>/dev/null && pwd -P
)"
CLI="$ROOT_DIR/repohealth"
FIXTURES_DIR="$ROOT_DIR/tests/fixtures"
TMP_ROOT=""
UPDATE_SNAPSHOTS="${UPDATE_SNAPSHOTS:-0}"

cleanup() {
  if [ -n "${TMP_ROOT:-}" ] && [ -d "$TMP_ROOT" ]; then
    rm -rf "$TMP_ROOT"
  fi
}

fail() {
  printf 'FAIL: %s\n' "$*" >&2
  exit 1
}

make_temp_dir() {
  local base="${TMPDIR:-/tmp}"
  mktemp -d "$base/repohealth-tests.XXXXXX"
}

write_file() {
  local path="$1"
  local content="$2"
  mkdir -p "$(dirname "$path")"
  printf '%s' "$content" >"$path"
}

write_executable() {
  local path="$1"
  local content="$2"
  write_file "$path" "$content"
  chmod +x "$path"
}

init_git_repo() {
  local path="$1"
  mkdir -p "$path"
  if ! git init --initial-branch=main "$path" >/dev/null 2>&1; then
    git init "$path" >/dev/null 2>&1
    git -C "$path" checkout -b main >/dev/null 2>&1 || git -C "$path" branch -M main >/dev/null 2>&1
  fi
  git -C "$path" config user.name "Repohealth Tests"
  git -C "$path" config user.email "repohealth-tests@example.com"
}

init_bare_repo() {
  local path="$1"
  mkdir -p "$(dirname "$path")"
  git init --bare "$path" >/dev/null 2>&1
}

commit_all() {
  local repo="$1"
  local message="$2"
  local stamp="$3"
  git -C "$repo" add -A
  GIT_AUTHOR_NAME="Repohealth Tests" \
    GIT_AUTHOR_EMAIL="repohealth-tests@example.com" \
    GIT_AUTHOR_DATE="$stamp" \
    GIT_COMMITTER_NAME="Repohealth Tests" \
    GIT_COMMITTER_EMAIL="repohealth-tests@example.com" \
    GIT_COMMITTER_DATE="$stamp" \
    git -C "$repo" commit -m "$message" >/dev/null 2>&1
}

build_workspace() {
  local workspace="$TMP_ROOT/workspace"
  local remotes="$TMP_ROOT/remotes"
  mkdir -p "$workspace" "$remotes"

  init_bare_repo "$remotes/clean-upstream.git"
  init_git_repo "$workspace/clean-upstream"
  write_file "$workspace/clean-upstream/README.md" $'clean repo\n'
  commit_all "$workspace/clean-upstream" "Initial clean commit" "2024-01-01T00:00:00 +0000"
  git -C "$workspace/clean-upstream" remote add origin "$remotes/clean-upstream.git"
  git -C "$workspace/clean-upstream" push -u origin main >/dev/null 2>&1

  init_bare_repo "$remotes/ahead-dirty.git"
  init_git_repo "$workspace/ahead-dirty"
  write_file "$workspace/ahead-dirty/tracked.txt" $'alpha\n'
  commit_all "$workspace/ahead-dirty" "Initial upstream commit" "2024-01-02T00:00:00 +0000"
  git -C "$workspace/ahead-dirty" remote add origin "$remotes/ahead-dirty.git"
  git -C "$workspace/ahead-dirty" push -u origin main >/dev/null 2>&1
  write_file "$workspace/ahead-dirty/tracked.txt" $'alpha\nbeta\n'
  commit_all "$workspace/ahead-dirty" "Add beta line" "2024-01-03T00:00:00 +0000"
  write_file "$workspace/ahead-dirty/tracked.txt" $'alpha\nbeta\nworktree\n'
  write_file "$workspace/ahead-dirty/notes.tmp" $'scratch\n'

  init_git_repo "$workspace/no-remote"
  write_file "$workspace/no-remote/local.txt" $'local only\n'
  commit_all "$workspace/no-remote" "Local only commit" "2024-01-04T00:00:00 +0000"

  printf '%s' "$workspace"
}

run_cli() {
  local stdout_file="$1"
  local stderr_file="$2"
  local status_file="$3"
  shift 3

  local status=0
  set +e
  env LC_ALL=C TZ=UTC COLUMNS=80 NO_COLOR=1 "$CLI" "$@" >"$stdout_file" 2>"$stderr_file"
  status=$?
  set -e
  printf '%s\n' "$status" >"$status_file"
}

compare_file() {
  local label="$1"
  local expected="$2"
  local actual="$3"

  if [ "$UPDATE_SNAPSHOTS" = "1" ]; then
    mkdir -p "$(dirname "$expected")"
    cp "$actual" "$expected"
    return
  fi

  if git diff --no-index --quiet -- "$expected" "$actual" >/dev/null 2>&1; then
    return
  fi

  printf 'Snapshot mismatch: %s\n' "$label" >&2
  git diff --no-index -- "$expected" "$actual" >&2 || true
  exit 1
}

assert_snapshot() {
  local name="$1"
  local directory="$2"
  shift 2

  local stdout_actual="$TMP_ROOT/${name}.stdout"
  local stderr_actual="$TMP_ROOT/${name}.stderr"
  local status_actual="$TMP_ROOT/${name}.status"

  run_cli "$stdout_actual" "$stderr_actual" "$status_actual" "$@" "$directory"

  compare_file "$name stdout" "$FIXTURES_DIR/${name}.stdout" "$stdout_actual"
  compare_file "$name stderr" "$FIXTURES_DIR/${name}.stderr" "$stderr_actual"
  compare_file "$name status" "$FIXTURES_DIR/${name}.status" "$status_actual"
}

assert_jobs_consistent() {
  local directory="$1"
  local seq_stdout="$TMP_ROOT/jobs-seq.stdout"
  local seq_stderr="$TMP_ROOT/jobs-seq.stderr"
  local seq_status="$TMP_ROOT/jobs-seq.status"
  local par_stdout="$TMP_ROOT/jobs-par.stdout"
  local par_stderr="$TMP_ROOT/jobs-par.stderr"
  local par_status="$TMP_ROOT/jobs-par.status"

  run_cli "$seq_stdout" "$seq_stderr" "$seq_status" --jobs 1 "$directory"
  run_cli "$par_stdout" "$par_stderr" "$par_status" "$directory"

  compare_file "jobs stdout" "$seq_stdout" "$par_stdout"
  compare_file "jobs stderr" "$seq_stderr" "$par_stderr"
  compare_file "jobs status" "$seq_status" "$par_status"
}

assert_default_jobs_floor() {
  local workspace="$TMP_ROOT/default-jobs-workspace"
  local fakebin="$TMP_ROOT/default-jobs-bin"
  local stdout_file="$TMP_ROOT/default-jobs.stdout"
  local stderr_file="$TMP_ROOT/default-jobs.stderr"
  local status_file="$TMP_ROOT/default-jobs.status"
  local active_file="$TMP_ROOT/default-jobs.active"
  local max_file="$TMP_ROOT/default-jobs.max"
  local lock_dir="$TMP_ROOT/default-jobs.lock"
  local i max_active

  mkdir -p "$workspace" "$fakebin"
  for i in $(seq 1 16); do
    mkdir -p "$workspace/repo-$i/.git"
  done

  write_file "$active_file" $'0\n'
  write_file "$max_file" $'0\n'

  write_executable "$fakebin/getconf" $'#!/usr/bin/env bash\nif [ "${1:-}" = "_NPROCESSORS_ONLN" ]; then\n  printf \'4\\n\'\nelse\n  /usr/bin/getconf "$@"\nfi\n'
  write_executable "$fakebin/git" $'#!/usr/bin/env bash\nset -euo pipefail\n\nif [ "${1:-}" = "-C" ]; then\n  shift 2\nfi\n\nif [ "${1:-}" != "status" ]; then\n  printf \'unsupported fake git command: %s\\n\' "${1:-}" >&2\n  exit 1\nfi\n\nlock_dir="${REPOHEALTH_TEST_LOCK_DIR:?}"\nactive_file="${REPOHEALTH_TEST_ACTIVE_FILE:?}"\nmax_file="${REPOHEALTH_TEST_MAX_FILE:?}"\n\nlock() {\n  while ! mkdir "$lock_dir" 2>/dev/null; do\n    sleep 0.01\n  done\n}\n\nunlock() {\n  rmdir "$lock_dir"\n}\n\nlock\nactive="$(cat "$active_file" 2>/dev/null || printf \'0\')"\nactive=$((active + 1))\nprintf \'%s\\n\' "$active" >"$active_file"\nmax_active="$(cat "$max_file" 2>/dev/null || printf \'0\')"\nif [ "$active" -gt "$max_active" ]; then\n  printf \'%s\\n\' "$active" >"$max_file"\nfi\nunlock\n\nsleep 0.25\n\nlock\nactive="$(cat "$active_file" 2>/dev/null || printf \'0\')"\nif [ "$active" -gt 0 ]; then\n  active=$((active - 1))\nfi\nprintf \'%s\\n\' "$active" >"$active_file"\nunlock\n\nprintf \'# branch.oid %s\\n\' \'0123456789abcdef0123456789abcdef01234567\'\nprintf \'# branch.head main\\n\'\nprintf \'# branch.upstream origin/main\\n\'\nprintf \'# branch.ab +0 -0\\n\'\n'

  local status=0
  set +e
  env \
    LC_ALL=C \
    TZ=UTC \
    COLUMNS=80 \
    NO_COLOR=1 \
    PATH="$fakebin:$PATH" \
    REPOHEALTH_TEST_ACTIVE_FILE="$active_file" \
    REPOHEALTH_TEST_MAX_FILE="$max_file" \
    REPOHEALTH_TEST_LOCK_DIR="$lock_dir" \
    "$CLI" "$workspace" >"$stdout_file" 2>"$stderr_file"
  status=$?
  set -e
  printf '%s\n' "$status" >"$status_file"

  [ "$status" -eq 0 ] || fail "default jobs floor run failed with status $status"
  [ ! -s "$stderr_file" ] || fail "default jobs floor run wrote unexpected stderr"

  max_active="$(cat "$max_file")"
  [ "$max_active" -ge 8 ] || fail "expected auto-detected default jobs floor to reach at least 8 workers, saw $max_active"
}

assert_minimal_rejects_detail() {
  local workspace="$1"
  local stdout_file="$TMP_ROOT/minimal-detail.stdout"
  local stderr_file="$TMP_ROOT/minimal-detail.stderr"
  local status_file="$TMP_ROOT/minimal-detail.status"
  local status=0

  set +e
  env LC_ALL=C TZ=UTC COLUMNS=80 NO_COLOR=1 "$CLI" --output minimal --detail "$workspace" >"$stdout_file" 2>"$stderr_file"
  status=$?
  set -e
  printf '%s\n' "$status" >"$status_file"

  [ "$status" -ne 0 ] || fail "expected --output minimal --detail to fail"
  grep -F -- '--detail is not supported with --output minimal' "$stderr_file" >/dev/null ||
    fail "expected minimal detail error message"
  [ ! -s "$stdout_file" ] || fail "expected minimal detail failure to avoid stdout output"
}

assert_minimal_uses_repo_basename() {
  local workspace="$TMP_ROOT/minimal-name-workspace"
  local nested_repo="$workspace/parent/child/nested-repo"
  local stdout_file="$TMP_ROOT/minimal-name.stdout"
  local stderr_file="$TMP_ROOT/minimal-name.stderr"
  local status_file="$TMP_ROOT/minimal-name.status"

  init_git_repo "$nested_repo"
  write_file "$nested_repo/file.txt" $'hello\n'
  commit_all "$nested_repo" "Initial commit" "2024-01-06T00:00:00 +0000"

  run_cli "$stdout_file" "$stderr_file" "$status_file" --jobs 1 --output minimal "$workspace"

  [ ! -s "$stderr_file" ] || fail "expected minimal basename run to avoid stderr"
  grep -E '^nested-repo  g ' "$stdout_file" >/dev/null || fail "expected minimal output to show repo basename"
  if grep -F 'parent/child/nested-repo' "$stdout_file" >/dev/null 2>&1; then
    fail "expected minimal output to avoid relative path names"
  fi
}

assert_jj_discovery_prefers_jj() {
  local workspace="$TMP_ROOT/jj-discovery-workspace"
  local fakebin="$TMP_ROOT/jj-discovery-bin"
  local stdout_file="$TMP_ROOT/jj-discovery.stdout"
  local stderr_file="$TMP_ROOT/jj-discovery.stderr"
  local status_file="$TMP_ROOT/jj-discovery.status"
  local calls_file="$TMP_ROOT/jj-discovery.calls"

  mkdir -p "$workspace" "$fakebin"

  init_git_repo "$workspace/mixed"
  write_file "$workspace/mixed/file.txt" $'hello\n'
  commit_all "$workspace/mixed" "Initial commit" "2024-01-05T00:00:00 +0000"
  mkdir -p "$workspace/mixed/.jj"

  write_file "$calls_file" ''
  write_executable "$fakebin/jj" $'#!/usr/bin/env bash\nset -euo pipefail\ncalls_file="${REPOHEALTH_TEST_JJ_CALLS_FILE:?}"\nprintf \'%s\\n\' "$*" >>"$calls_file"\n\nif [ "${1:-}" != "-R" ]; then\n  printf \'unexpected jj invocation: %s\\n\' "$*" >&2\n  exit 1\nfi\nshift 2\n\ncase "${1:-}" in\n  root)\n    printf \'jj root should not be called during discovery\\n\' >&2\n    exit 99\n    ;;\n  log)\n    if [ "${3:-}" = "--count" ] || [ "${4:-}" = "--count" ]; then\n      printf \'0\\n\'\n      exit 0\n    fi\n    ;;\n  git)\n    case "${2:-}" in\n      remote)\n        exit 0\n        ;;\n      push)\n        printf \'Nothing changed.\\nDry-run requested, not pushing.\\n\'\n        exit 0\n        ;;\n    esac\n    ;;\n  status)\n    exit 0\n    ;;\n  diff)\n    exit 0\n    ;;\n esac\n\nprintf \'unexpected jj invocation: %s\\n\' "$*" >&2\nexit 1\n'

  local status=0
  set +e
  env \
    LC_ALL=C \
    TZ=UTC \
    COLUMNS=80 \
    NO_COLOR=1 \
    PATH="$fakebin:$PATH" \
    REPOHEALTH_TEST_JJ_CALLS_FILE="$calls_file" \
    "$CLI" --jobs 1 "$workspace" >"$stdout_file" 2>"$stderr_file"
  status=$?
  set -e
  printf '%s\n' "$status" >"$status_file"

  [ "$status" -eq 0 ] || fail "jj discovery preference run failed with status $status"
  [ ! -s "$stderr_file" ] || fail "jj discovery preference run wrote unexpected stderr"
  grep -F 'mixed  [jj]' "$stdout_file" >/dev/null || fail "expected colocated .git/.jj repo to be reported as [jj]"
  if grep -F ' root' "$calls_file" >/dev/null 2>&1; then
    fail "expected jj discovery to avoid jj root probe"
  fi
}

assert_jj_work_state_uses_diff_only() {
  local workspace="$TMP_ROOT/jj-workspace"
  local fakebin="$TMP_ROOT/jj-work-bin"
  local stdout_file="$TMP_ROOT/jj-work.stdout"
  local stderr_file="$TMP_ROOT/jj-work.stderr"
  local status_file="$TMP_ROOT/jj-work.status"
  local jj_calls_file="$TMP_ROOT/jj-work.jj-calls"
  local git_calls_file="$TMP_ROOT/jj-work.git-calls"

  mkdir -p "$workspace" "$fakebin"
  mkdir -p "$workspace/jj-clean/.jj" "$workspace/jj-dirty/.jj" "$workspace/mixed/.jj" "$workspace/mixed/.git"

  write_file "$jj_calls_file" ''
  write_file "$git_calls_file" ''

  write_executable "$fakebin/jj" $'#!/usr/bin/env bash\nset -euo pipefail\ncalls_file="${REPOHEALTH_TEST_JJ_CALLS_FILE:?}"\nprintf \'%s\\n\' "$*" >>"$calls_file"\n\nif [ "${1:-}" != "-R" ]; then\n  printf \'unexpected jj invocation: %s\\n\' "$*" >&2\n  exit 1\nfi\nroot="${2:-}"\nrepo_name="${root##*/}"\nshift 2\n\ncase "${1:-}" in\n  status)\n    printf \'jj status should not be called\\n\' >&2\n    exit 99\n    ;;\n  diff)\n    if [ "${2:-}" != "--name-only" ]; then\n      printf \'unexpected jj diff invocation: %s\\n\' "$*" >&2\n      exit 1\n    fi\n    case "$repo_name" in\n      jj-clean)\n        exit 0\n        ;;\n      jj-dirty)\n        printf \'alpha.txt\\nbeta.txt\\n\'\n        exit 0\n        ;;\n      mixed)\n        printf \'jj diff should not run for mixed repo\\n\' >&2\n        exit 88\n        ;;\n    esac\n    ;;\n  log)\n    if [ "${3:-}" = "--count" ] || [ "${4:-}" = "--count" ]; then\n      printf \'0\\n\'\n      exit 0\n    fi\n    exit 0\n    ;;\n  git)\n    if [ "${2:-}" = "remote" ]; then\n      exit 0\n    fi\n    printf \'unexpected jj git invocation: %s\\n\' "$*" >&2\n    exit 1\n    ;;\n esac\n\nprintf \'unexpected jj invocation: %s\\n\' "$*" >&2\nexit 1\n'

  write_executable "$fakebin/git" $'#!/usr/bin/env bash\nset -euo pipefail\ncalls_file="${REPOHEALTH_TEST_GIT_CALLS_FILE:?}"\nprintf \'%s\\n\' "$*" >>"$calls_file"\n\nroot=""\nif [ "${1:-}" = "-C" ]; then\n  root="${2:-}"\n  shift 2\nfi\n\ncase "${1:-}" in\n  status)\n    if [ "${root##*/}" = "mixed" ]; then\n      printf \' M tracked.txt\\n\'\n    fi\n    exit 0\n    ;;\n esac\n\nprintf \'unexpected git invocation: %s\\n\' "$*" >&2\nexit 1\n'

  local status=0
  set +e
  env \
    LC_ALL=C \
    TZ=UTC \
    COLUMNS=80 \
    NO_COLOR=1 \
    PATH="$fakebin:$PATH" \
    REPOHEALTH_TEST_JJ_CALLS_FILE="$jj_calls_file" \
    REPOHEALTH_TEST_GIT_CALLS_FILE="$git_calls_file" \
    "$CLI" --jobs 1 "$workspace" >"$stdout_file" 2>"$stderr_file"
  status=$?
  set -e
  printf '%s\n' "$status" >"$status_file"

  [ "$status" -eq 0 ] || fail "jj work-state run failed with status $status"
  [ ! -s "$stderr_file" ] || fail "jj work-state run wrote unexpected stderr"

  grep -E 'jj-clean +\[jj\].*\|  - clean *$' "$stdout_file" >/dev/null || fail "expected clean jj repo to remain clean"
  grep -E 'jj-dirty +\[jj\].*\|  \* 2 modified *$' "$stdout_file" >/dev/null || fail "expected dirty jj repo to report two modified files"
  grep -E 'mixed +\[jj\].*\|  \* 1 modified *$' "$stdout_file" >/dev/null || fail "expected mixed repo to use git work-state fallback"

  if grep -F ' status' "$jj_calls_file" >/dev/null 2>&1; then
    fail "expected jj work-state collection to avoid jj status"
  fi
  if grep -F -- "$workspace/mixed diff --name-only" "$jj_calls_file" >/dev/null 2>&1; then
    fail "expected mixed repo to skip jj diff work-state collection"
  fi
  grep -E -- '-C .*/mixed status --porcelain=v1 --untracked-files=normal$' "$git_calls_file" >/dev/null || fail "expected mixed repo to use git status for work-state fallback"
}

assert_jj_push_state_defers_draft_count() {
  local workspace="$TMP_ROOT/jj-push-workspace"
  local fakebin="$TMP_ROOT/jj-push-bin"
  local stdout_file="$TMP_ROOT/jj-push.stdout"
  local stderr_file="$TMP_ROOT/jj-push.stderr"
  local status_file="$TMP_ROOT/jj-push.status"
  local minimal_stdout_file="$TMP_ROOT/jj-push-minimal.stdout"
  local minimal_stderr_file="$TMP_ROOT/jj-push-minimal.stderr"
  local minimal_status_file="$TMP_ROOT/jj-push-minimal.status"
  local calls_file="$TMP_ROOT/jj-push.calls"

  mkdir -p "$workspace" "$fakebin"
  mkdir -p \
    "$workspace/clean-remote/.jj" \
    "$workspace/draft-only/.jj" \
    "$workspace/outgoing/.jj" \
    "$workspace/no-remote/.jj"

  write_file "$calls_file" ''

  write_executable "$fakebin/jj" $'#!/usr/bin/env bash\nset -euo pipefail\ncalls_file="${REPOHEALTH_TEST_JJ_CALLS_FILE:?}"\nprintf \'%s\\n\' "$*" >>"$calls_file"\n\nif [ "${1:-}" != "-R" ]; then\n  printf \'unexpected jj invocation: %s\\n\' "$*" >&2\n  exit 1\nfi\nroot="${2:-}"\nrepo_name="${root##*/}"\nshift 2\n\ncase "${1:-}" in\n  diff)\n    if [ "${2:-}" != "--name-only" ]; then\n      printf \'unexpected jj diff invocation: %s\\n\' "$*" >&2\n      exit 1\n    fi\n    exit 0\n    ;;\n  git)\n    case "${2:-}" in\n      remote)\n        case "$repo_name" in\n          no-remote)\n            exit 0\n            ;;\n          *)\n            printf \'origin\\n\'\n            exit 0\n            ;;\n        esac\n        ;;\n      push)\n        case "$repo_name" in\n          clean-remote)\n            printf \'Nothing changed.\\nDry-run requested, not pushing.\\n\'\n            exit 0\n            ;;\n          draft-only)\n            printf \'Warning: No bookmarks found in the default push revset: remote_bookmarks(remote=origin)..@\\nNothing changed.\\nDry-run requested, not pushing.\\n\'\n            exit 0\n            ;;\n          outgoing)\n            printf \'Changes to push to origin:\\n  Move bookmark main from 11111111 to 22222222\\nDry-run requested, not pushing.\\n\'\n            exit 0\n            ;;\n          no-remote)\n            printf \'jj git push should not run for no-remote\\n\' >&2\n            exit 88\n            ;;\n        esac\n        ;;\n    esac\n    ;;\n  log)\n    if [[ "$*" == *"reachable(@, mutable()) ~ ::bookmarks() ~ @"* ]]; then\n      case "$repo_name" in\n        draft-only|outgoing)\n          printf \'2\\n\'\n          ;;\n        no-remote)\n          printf \'0\\n\'\n          ;;\n        clean-remote)\n          printf \'clean-remote draft count should be skipped\\n\' >&2\n          exit 77\n          ;;\n      esac\n      exit 0\n    fi\n    if [[ "$*" == *"::bookmarks() ~ ::remote_bookmarks(remote=origin)"* ]]; then\n      printf \'1\\n\'\n      exit 0\n    fi\n    ;;\n esac\n\nprintf \'unexpected jj invocation: %s\\n\' "$*" >&2\nexit 1\n'

  local status=0
  set +e
  env \
    LC_ALL=C \
    TZ=UTC \
    COLUMNS=80 \
    NO_COLOR=1 \
    PATH="$fakebin:$PATH" \
    REPOHEALTH_TEST_JJ_CALLS_FILE="$calls_file" \
    "$CLI" --jobs 1 "$workspace" >"$stdout_file" 2>"$stderr_file"
  status=$?
  set -e
  printf '%s\n' "$status" >"$status_file"

  [ "$status" -eq 0 ] || fail "jj push-state run failed with status $status"
  [ ! -s "$stderr_file" ] || fail "jj push-state run wrote unexpected stderr"

  grep -E 'clean-remote +\[jj\].*- up to date.*\|  - clean *$' "$stdout_file" >/dev/null || fail "expected clean remote jj repo to remain up to date"
  grep -E 'draft-only +\[jj\].*~ 2 draft only.*\|  - clean *$' "$stdout_file" >/dev/null || fail "expected draft-only jj repo to report draft-only state"
  grep -E 'outgoing +\[jj\].*↑ 1 outgoing \(\+2 draft\).*\|  - clean *$' "$stdout_file" >/dev/null || fail "expected outgoing jj repo to include draft suffix"
  grep -E 'no-remote +\[jj\].*\? no remote.*\|  - clean *$' "$stdout_file" >/dev/null || fail "expected no-remote jj repo to report missing remote"

  if grep -F 'clean-remote log -r reachable(@, mutable()) ~ ::bookmarks() ~ @' "$calls_file" >/dev/null 2>&1; then
    fail "expected clean JJ repo with remotes to skip draft counting"
  fi
  grep -F 'draft-only log -r reachable(@, mutable()) ~ ::bookmarks() ~ @' "$calls_file" >/dev/null || fail "expected draft-only jj repo to count drafts"
  grep -F 'outgoing log -r reachable(@, mutable()) ~ ::bookmarks() ~ @' "$calls_file" >/dev/null || fail "expected outgoing jj repo to count drafts for suffix reporting"
  grep -F 'no-remote log -r reachable(@, mutable()) ~ ::bookmarks() ~ @' "$calls_file" >/dev/null || fail "expected no-remote jj repo to count drafts for classification"
  if grep -F 'no-remote git push --dry-run' "$calls_file" >/dev/null 2>&1; then
    fail "expected no-remote jj repo to skip dry-run push"
  fi

  set +e
  env \
    LC_ALL=C \
    TZ=UTC \
    COLUMNS=80 \
    NO_COLOR=1 \
    PATH="$fakebin:$PATH" \
    REPOHEALTH_TEST_JJ_CALLS_FILE="$calls_file" \
    "$CLI" --jobs 1 --output minimal "$workspace" >"$minimal_stdout_file" 2>"$minimal_stderr_file"
  status=$?
  set -e
  printf '%s\n' "$status" >"$minimal_status_file"

  [ "$status" -eq 0 ] || fail "minimal jj push-state run failed with status $status"
  [ ! -s "$minimal_stderr_file" ] || fail "expected minimal jj push-state run to avoid stderr"
  grep -E '^clean-remote +j +\- +\- *$' "$minimal_stdout_file" >/dev/null || fail "expected clean JJ repo to remain clean in minimal output"
  grep -E '^draft-only +j +~2 D +\- *$' "$minimal_stdout_file" >/dev/null || fail "expected draft-only JJ repo to show draft count in minimal output"
  grep -E '^outgoing +j +↑1 O \+2 D +\- *$' "$minimal_stdout_file" >/dev/null || fail "expected outgoing JJ repo to include draft suffix in minimal output"
  grep -E '^no-remote +j +\? +\- *$' "$minimal_stdout_file" >/dev/null || fail "expected no-remote JJ repo to remain a question state in minimal output"
}

assert_jj_push_detail_preserves_draft_detail() {
  local workspace="$TMP_ROOT/jj-push-detail-workspace"
  local fakebin="$TMP_ROOT/jj-push-detail-bin"
  local stdout_file="$TMP_ROOT/jj-push-detail.stdout"
  local stderr_file="$TMP_ROOT/jj-push-detail.stderr"
  local status_file="$TMP_ROOT/jj-push-detail.status"

  mkdir -p "$workspace" "$fakebin"
  mkdir -p "$workspace/outgoing/.jj"

  write_executable "$fakebin/jj" $'#!/usr/bin/env bash\nset -euo pipefail\n\nif [ "${1:-}" != "-R" ]; then\n  printf \'unexpected jj invocation: %s\\n\' "$*" >&2\n  exit 1\nfi\nroot="${2:-}"\nrepo_name="${root##*/}"\nshift 2\n\ncase "${1:-}" in\n  diff)\n    if [ "${2:-}" != "--name-only" ]; then\n      printf \'unexpected jj diff invocation: %s\\n\' "$*" >&2\n      exit 1\n    fi\n    exit 0\n    ;;\n  git)\n    case "${2:-}" in\n      remote)\n        printf \'origin\\n\'\n        exit 0\n        ;;\n      push)\n        printf \'Changes to push to origin:\\n  Move bookmark main from 11111111 to 22222222\\nDry-run requested, not pushing.\\n\'\n        exit 0\n        ;;\n    esac\n    ;;\n  log)\n    if [[ "$*" == *"reachable(@, mutable()) ~ ::bookmarks() ~ @"* ]]; then\n      if [[ "$*" == *"--count"* ]]; then\n        printf \'2\\n\'\n      else\n        printf \'draft-1 first draft\\ndraft-2 second draft\\n\'\n      fi\n      exit 0\n    fi\n    if [[ "$*" == *"::bookmarks() ~ ::remote_bookmarks(remote=origin)"* ]]; then\n      if [[ "$*" == *"--count"* ]]; then\n        printf \'1\\n\'\n      else\n        printf \'__COMMIT__\\tfeedface\\tPush change\\n3\\t1\\tsrc/main.txt\\n__END__\\n\'\n      fi\n      exit 0\n    fi\n    ;;\n esac\n\nprintf \'unexpected jj invocation: %s\\n\' "$*" >&2\nexit 1\n'

  local status=0
  set +e
  env \
    LC_ALL=C \
    TZ=UTC \
    COLUMNS=80 \
    NO_COLOR=1 \
    PATH="$fakebin:$PATH" \
    "$CLI" --jobs 1 --output json --detail "$workspace" >"$stdout_file" 2>"$stderr_file"
  status=$?
  set -e
  printf '%s\n' "$status" >"$status_file"

  [ "$status" -eq 0 ] || fail "jj push detail run failed with status $status"
  [ ! -s "$stderr_file" ] || fail "jj push detail run wrote unexpected stderr"

  grep -F '"text": "↑ 1 outgoing (+2 draft)"' "$stdout_file" >/dev/null || fail "expected JJ detail output to preserve outgoing draft suffix"
  grep -F '"drafts": [' "$stdout_file" >/dev/null || fail "expected JJ detail output to include draft detail array"
  grep -F '"draft-1 first draft"' "$stdout_file" >/dev/null || fail "expected JJ detail output to include first draft entry"
  grep -F '"draft-2 second draft"' "$stdout_file" >/dev/null || fail "expected JJ detail output to include second draft entry"
  grep -F '"title": "feedface Push change"' "$stdout_file" >/dev/null || fail "expected JJ detail output to include outgoing commit detail"
  grep -F '"path": "src/main.txt"' "$stdout_file" >/dev/null || fail "expected JJ detail output to include outgoing file stats"
}

main() {
  trap cleanup EXIT

  [ -x "$CLI" ] || fail "repohealth is not executable: $CLI"
  [ -d "$FIXTURES_DIR" ] || fail "fixtures directory is missing: $FIXTURES_DIR"

  TMP_ROOT="$(make_temp_dir)"

  local workspace
  workspace="$(build_workspace)"

  mkdir -p "$TMP_ROOT/empty"

  assert_snapshot "empty" "$TMP_ROOT/empty" --jobs 1
  assert_snapshot "default" "$workspace" --jobs 1
  assert_snapshot "minimal" "$workspace" --jobs 1 --output minimal
  assert_snapshot "dirty" "$workspace" --jobs 1 --dirty
  assert_snapshot "minimal-dirty" "$workspace" --jobs 1 --output minimal --dirty
  assert_snapshot "exclude-single" "$workspace" --jobs 1 --exclude 'no-remote'
  assert_snapshot "exclude-multi" "$workspace" --jobs 1 --exclude 'no-remote' --exclude 'clean'
  assert_snapshot "detail" "$workspace/ahead-dirty" --jobs 1 --output detail
  assert_snapshot "detail-fancy" "$workspace/ahead-dirty" --jobs 1 --output fancy-detail
  assert_snapshot "format-json" "$workspace" --jobs 1 --output json
  assert_snapshot "format-json-detail" "$workspace/ahead-dirty" --jobs 1 --output json --detail
  assert_jobs_consistent "$workspace"
  assert_default_jobs_floor
  assert_minimal_rejects_detail "$workspace"
  assert_minimal_uses_repo_basename
  assert_jj_discovery_prefers_jj
  assert_jj_work_state_uses_diff_only
  assert_jj_push_state_defers_draft_count
  assert_jj_push_detail_preserves_draft_detail

  # multi-directory: scan two separate roots
  local dir_a="$TMP_ROOT/multi-a"
  local dir_b="$TMP_ROOT/multi-b"
  init_git_repo "$dir_a/alpha"
  write_file "$dir_a/alpha/file.txt" $'hello\n'
  commit_all "$dir_a/alpha" "Initial commit" "2024-01-01T00:00:00 +0000"
  init_git_repo "$dir_b/beta"
  write_file "$dir_b/beta/file.txt" $'world\n'
  commit_all "$dir_b/beta" "Initial commit" "2024-01-01T00:00:00 +0000"
  local multi_stdout="$TMP_ROOT/multi-dir.stdout"
  local multi_stderr="$TMP_ROOT/multi-dir.stderr"
  local multi_status="$TMP_ROOT/multi-dir.status"
  run_cli "$multi_stdout" "$multi_stderr" "$multi_status" --jobs 1 "$dir_a" "$dir_b"
  compare_file "multi-dir stdout" "$FIXTURES_DIR/multi-dir.stdout" "$multi_stdout"
  compare_file "multi-dir stderr" "$FIXTURES_DIR/multi-dir.stderr" "$multi_stderr"
  compare_file "multi-dir status" "$FIXTURES_DIR/multi-dir.status" "$multi_status"

  printf 'All snapshot tests passed.\n'
}

main "$@"
